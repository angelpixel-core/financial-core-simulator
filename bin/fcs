#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../lib/fcs"
require "optparse"
require "benchmark"

subcommand = ARGV.shift

case subcommand
when "run"
  options = {
    input: nil,
    output_dir: "output",
    fee_enabled: true,
    explain: false,
    verbose: false
  }

  parser = OptionParser.new do |opts|
    opts.banner = "Usage: fcs run --input path/to/input.json [--output-dir output] [--no-fee] [--explain] [--verbose]"

    opts.on("--input PATH", "Path to input JSON (required)") { |v| options[:input] = v }
    opts.on("--output-dir DIR", "Output directory (default: output)") { |v| options[:output_dir] = v }
    opts.on("--no-fee", "Disable fee model (ignore fee fields)") { options[:fee_enabled] = false }
    opts.on("--explain", "Include explainability fields in result.json") { options[:explain] = true }
    opts.on("--verbose", "Print CLI summary") { options[:verbose] = true }
    opts.on("-v", "--version", "Print version") { puts FCS::VERSION; exit(0) }
    opts.on("-h", "--help", "Print help") { puts opts; exit(0) }
  end

  parser.parse!(ARGV)

  if options[:input].nil? || options[:input].strip.empty?
    warn "ERR: --input is required"
    puts parser
    exit(2)
  end

  puts "FCS #{FCS::VERSION}"
  puts "Input: #{options[:input]}"
  puts "Output: #{options[:output_dir]}"
  puts "Fee enabled: #{options[:fee_enabled]}"
  puts "Explain: #{options[:explain]}"
  puts "Verbose: #{options[:verbose]}"

  runner = FCS::Application::Runner.new
  path = runner.run!(
    input_path: options[:input],
    output_dir: options[:output_dir],
    fee_enabled: options[:fee_enabled],
    explain: options[:explain],
    verbose: options[:verbose]
  )

  puts "OK: wrote #{path}"

when "bench"
  bench = {
    trades: 100_000,
    accounts: 10,
    markets: 5
  }

  parser = OptionParser.new do |opts|
    opts.banner = "Usage: fcs bench [--trades N] [--accounts N] [--markets N]"

    opts.on("--trades N", Integer, "Number of trades (default: 100000)") { |v| bench[:trades] = v }
    opts.on("--accounts N", Integer, "Number of accounts (default: 10)") { |v| bench[:accounts] = v }
    opts.on("--markets N", Integer, "Number of markets (default: 5)") { |v| bench[:markets] = v }
    opts.on("-v", "--version", "Print version") { puts FCS::VERSION; exit(0) }
    opts.on("-h", "--help", "Print help") { puts opts; exit(0) }
  end

  parser.parse!(ARGV)

  input = FCS::Benchmarking::InputGenerator.new.generate(
    trades: bench[:trades],
    accounts: bench[:accounts],
    markets: bench[:markets]
  )

  simulate = FCS::Application::Simulate.new

  elapsed = Benchmark.realtime do
    simulate.call(input)
  end

  puts "Bench:"
  puts "  trades=#{bench[:trades]} accounts=#{bench[:accounts]} markets=#{bench[:markets]}"
  puts format("  elapsed=%.3fs", elapsed)

else
  puts <<~TXT
    Usage:
      fcs run   --input path/to/input.json [--output-dir output] [--no-fee] [--explain] [--verbose]
      fcs bench [--trades N] [--accounts N] [--markets N]

    Examples:
      fcs run --input lib/fcs/fixtures/demo_input.json --output-dir output
      fcs run --input lib/fcs/fixtures/demo_input.json --output-dir output --explain --verbose
      fcs bench
      fcs bench --trades 200000 --accounts 20 --markets 10
  TXT
  exit(1)
end
