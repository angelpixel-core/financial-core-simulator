#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../lib/fcs"
require "optparse"
require "json"

def t(key, **opts)
  ::I18n.t(key, **opts)
end

def print_diagnostic_error(code:, what_happened:, impact:, next_action:, details: {})
  payload = {
    "error" => {
      "code" => code,
      "message" => what_happened
    },
    "code" => code,
    "what_happened" => what_happened,
    "impact" => impact,
    "next_action" => next_action,
    "details" => details
  }

  warn(JSON.pretty_generate(payload))
end

def print_diagnostic_warning(code:, what_happened:, impact:, next_action:, details: {})
  payload = {
    "warning" => {
      "code" => code,
      "message" => what_happened
    },
    "code" => code,
    "what_happened" => what_happened,
    "impact" => impact,
    "next_action" => next_action,
    "details" => details
  }

  warn(JSON.pretty_generate(payload))
end

def required_artifact_paths(output_dir)
  {
    "result_json" => File.join(output_dir, "result.json"),
    "positions_csv" => File.join(output_dir, "positions.csv"),
    "pnl_csv" => File.join(output_dir, "pnl.csv")
  }
end

def available_artifacts(expected)
  expected.select { |_key, path| File.exist?(path) }.keys.sort
end

def failure_summary_payload
  {
    "runId" => "n/a",
    "inputHash" => "n/a",
    "schemaVersion" => "n/a",
    "engineVersion" => FCS::VERSION,
    "valuationTimestamp" => "n/a",
    "global" => {
      "realizedPnLQuote" => nil,
      "feesQuote" => nil,
      "realizedNetPnLQuote" => nil,
      "unrealizedPnLQuote" => nil,
      "totalPnLQuote" => nil,
      "totalPnLUsd" => nil
    },
    "accounts" => []
  }
end

# Demo input generator for dashboard-friendly swings.
def build_demo_input(accounts:, markets:, trades:)
  account_ids = (1..accounts).map { |i| "acc-#{i}" }
  market_ids = (1..markets).map { |i| i == 1 ? "ETH-USD" : "MKT-#{i}" }

  inventory = Hash.new(0)
  seqs = Hash.new(0)
  out = []
  ts = 1

  trades.times do |i|
    acc = account_ids[i % account_ids.length]
    mkt = market_ids[(i / account_ids.length) % market_ids.length]
    key = "#{acc}|#{mkt}"

    side = inventory[key] <= 0 ? "BUY" : (i.even? ? "SELL" : "BUY")

    price = if side == "SELL"
      (i % 3).zero? ? "90" : "120"
    else
      (i % 4).zero? ? "130" : "100"
    end

    inventory[key] += (side == "BUY" ? 1 : -1)
    seqs[key] += 1

    out << {
      "tradeId" => "t-#{i + 1}",
      "accountId" => acc,
      "marketId" => mkt,
      "timestamp" => ts,
      "seq" => seqs[key],
      "side" => side,
      "quantityBase" => "1",
      "priceQuotePerBase" => price,
      "fee" => {"amountQuote" => "0.01"}
    }

    ts += 1
  end

  {
    "schemaVersion" => "1.0",
    "accounts" => account_ids.map { |id| {"accountId" => id} },
    "markets" => market_ids.map { |id| {"marketId" => id} },
    "feeModel" => {"enabled" => true},
    "trades" => out,
    "priceSnapshot" => {
      "valuationTimestamp" => "2026-02-25T03:00:00Z",
      "prices" => market_ids.map { |m| {"marketId" => m, "priceQuotePerBase" => "110"} },
      "fx" => {"quoteUsd" => "1"}
    }
  }
end

def warn_if_unsafe_output_dir(output_dir)
  repo_root = File.expand_path("..", __dir__)
  resolved_output_dir = File.expand_path(output_dir, repo_root)
  output_root = File.expand_path("output", repo_root)
  within_output = resolved_output_dir == output_root || resolved_output_dir.start_with?(output_root + File::SEPARATOR)

  unsafe_reason = if resolved_output_dir == repo_root
    "repo_root"
  elsif !within_output
    "outside_output"
  end

  return unless unsafe_reason

  print_diagnostic_warning(
    code: "WARN_UNSAFE_OUTPUT_DIR",
    what_happened: t("fcs.cli.warnings.unsafe_output_dir.what_happened"),
    impact: t("fcs.cli.warnings.unsafe_output_dir.impact"),
    next_action: t("fcs.cli.warnings.unsafe_output_dir.next_action"),
    details: {
      "output_dir" => output_dir,
      "resolved_output_dir" => resolved_output_dir,
      "repo_root" => repo_root,
      "output_root" => output_root,
      "unsafe_reason" => unsafe_reason
    }
  )
end

subcommand = ARGV.shift

case subcommand
when "run"
  options = {
    input: nil,
    output_dir: "output/fcs",
    fee_enabled: true,
    explain: false,
    verbose: false,
    quiet: true
  }

  parser = OptionParser.new do |opts|
    opts.banner = [
      t("fcs.cli.banners.run_usage"),
      t("fcs.cli.banners.run_usage_suffix")
    ].join(" ")

    opts.on("--input PATH", t("fcs.cli.options.input")) { |v| options[:input] = v }
    opts.on("--output-dir DIR", t("fcs.cli.options.output_dir_run")) { |v| options[:output_dir] = v }
    opts.on("--no-fee", t("fcs.cli.options.no_fee")) { options[:fee_enabled] = false }
    opts.on("--explain", t("fcs.cli.options.explain")) { options[:explain] = true }
    opts.on("--verbose", t("fcs.cli.options.verbose")) do
      options[:verbose] = true
      options[:quiet] = false
    end
    opts.on("--quiet", t("fcs.cli.options.quiet")) do
      options[:verbose] = false
      options[:quiet] = true
    end
    opts.on("-v", "--version", t("fcs.cli.options.version")) do
      puts FCS::VERSION
      exit(0)
    end
    opts.on("-h", "--help", t("fcs.cli.options.help")) do
      puts opts
      exit(0)
    end
  end

  begin
    parser.parse!(ARGV)
  rescue OptionParser::ParseError => e
    print_diagnostic_error(
      code: FCS::Errors::ERR_VALIDATION,
      what_happened: t("fcs.cli.diagnostics.run.invalid_cli_option.what_happened"),
      impact: t("fcs.cli.diagnostics.run.invalid_cli_option.impact"),
      next_action: t("fcs.cli.diagnostics.run.invalid_cli_option.next_action"),
      details: { "errorClass" => e.class.name, "errorMessage" => e.message }
    )
    exit(2)
  end

  if options[:input].nil? || options[:input].strip.empty?
    print_diagnostic_error(
      code: FCS::Errors::ERR_VALIDATION,
      what_happened: t("fcs.cli.diagnostics.run.input_required.what_happened"),
      impact: t("fcs.cli.diagnostics.run.input_required.impact"),
      next_action: t("fcs.cli.diagnostics.run.input_required.next_action"),
      details: { "usage" => parser.banner }
    )
    exit(2)
  end

  warn_if_unsafe_output_dir(options[:output_dir])

  unless options[:quiet]
    puts t("fcs.cli.run_info.version", version: FCS::VERSION)
    puts t("fcs.cli.run_info.input", path: options[:input])
    puts t("fcs.cli.run_info.output", path: options[:output_dir])
    puts t("fcs.cli.run_info.fee_enabled", value: options[:fee_enabled])
    puts t("fcs.cli.run_info.explain", value: options[:explain])
    puts t("fcs.cli.run_info.verbose", value: options[:verbose])
  end

  FCS.logger.level = options[:verbose] ? FCS::Logging::SimpleLogger::INFO : FCS::Logging::SimpleLogger::WARN

  begin
    runner = FCS::Application::Runner.new
    path = runner.run!(
      input_path: options[:input],
      output_dir: options[:output_dir],
      fee_enabled: options[:fee_enabled],
      explain: options[:explain],
      verbose: options[:verbose]
    )

    expected_artifacts = required_artifact_paths(options[:output_dir])
    missing_artifacts = expected_artifacts.reject { |_key, path| File.exist?(path) }
    if missing_artifacts.any?
      print_diagnostic_error(
        code: FCS::Errors::ERR_VALIDATION,
        what_happened: t("fcs.cli.diagnostics.run.missing_artifacts.what_happened"),
        impact: t("fcs.cli.diagnostics.run.missing_artifacts.impact"),
        next_action: t("fcs.cli.diagnostics.run.missing_artifacts.next_action"),
        details: {
          "missing_artifacts" => missing_artifacts,
          "expected_artifacts" => expected_artifacts
        }
      )
      exit(2)
    end

    puts t("fcs.cli.success.ok_wrote", path: path) unless options[:quiet]
  rescue FCS::Error => e
    expected_artifacts = required_artifact_paths(options[:output_dir])
    if options[:verbose]
      FCS::Reporting::CliSummary.new.print(
        failure_summary_payload,
        artifacts: {
          json_path: expected_artifacts["result_json"],
          positions_csv_path: expected_artifacts["positions_csv"],
          pnl_csv_path: expected_artifacts["pnl_csv"]
        },
        status: "failure",
        validate_artifacts: false
      )
    end
    details = (e.details || {}).merge(
      "run_status" => "failure",
      "output_dir" => options[:output_dir],
      "expected_artifacts" => expected_artifacts,
      "available_artifacts" => available_artifacts(expected_artifacts)
    )
    print_diagnostic_error(
      code: e.code,
      what_happened: e.message,
      impact: t("fcs.cli.diagnostics.run.failure.impact"),
      next_action: t("fcs.cli.diagnostics.run.failure.next_action"),
      details: details
    )
    exit(2)
  rescue StandardError => e
    expected_artifacts = required_artifact_paths(options[:output_dir])
    if options[:verbose]
      FCS::Reporting::CliSummary.new.print(
        failure_summary_payload,
        artifacts: {
          json_path: expected_artifacts["result_json"],
          positions_csv_path: expected_artifacts["positions_csv"],
          pnl_csv_path: expected_artifacts["pnl_csv"]
        },
        status: "failure",
        validate_artifacts: false
      )
    end
    print_diagnostic_error(
      code: "ERR_INTERNAL",
      what_happened: t("fcs.cli.diagnostics.run.unexpected_error.what_happened", error_class: e.class),
      impact: t("fcs.cli.diagnostics.run.unexpected_error.impact"),
      next_action: t("fcs.cli.diagnostics.run.unexpected_error.next_action"),
      details: {
        "message" => e.message,
        "run_status" => "failure",
        "output_dir" => options[:output_dir],
        "expected_artifacts" => expected_artifacts,
        "available_artifacts" => available_artifacts(expected_artifacts)
      }
    )
    exit(1)
  end

when "bench"
  options = {
    fixture: "lib/fcs/fixtures/benchmark_fixture.json",
    runs: FCS::Benchmarking::BenchmarkRunner::DEFAULT_RUNS,
    output_dir: "output/fcs/benchmarks"
  }

  parser = OptionParser.new do |opts|
    opts.banner = t("fcs.cli.banners.bench_usage")

    opts.on("--fixture PATH", t("fcs.cli.options.fixture")) { |v| options[:fixture] = v }
    opts.on("--runs N", Integer, t("fcs.cli.options.runs", runs: options[:runs])) { |v| options[:runs] = v }
    opts.on("--output-dir DIR", t("fcs.cli.options.output_dir_bench")) do |v|
      options[:output_dir] = v
    end
    opts.on("-v", "--version", t("fcs.cli.options.version")) do
      puts FCS::VERSION
      exit(0)
    end
    opts.on("-h", "--help", t("fcs.cli.options.help")) do
      puts opts
      exit(0)
    end
  end

  begin
    parser.parse!(ARGV)
  rescue OptionParser::ParseError => e
    print_diagnostic_error(
      code: FCS::Errors::ERR_VALIDATION,
      what_happened: t("fcs.cli.diagnostics.bench.invalid_cli_option.what_happened"),
      impact: t("fcs.cli.diagnostics.bench.invalid_cli_option.impact"),
      next_action: t("fcs.cli.diagnostics.bench.invalid_cli_option.next_action"),
      details: { "errorClass" => e.class.name, "errorMessage" => e.message }
    )
    exit(2)
  end

  command = "bin/fcs bench --fixture #{options[:fixture]} --runs #{options[:runs]} --output-dir #{options[:output_dir]}"

  begin
    warn_if_unsafe_output_dir(options[:output_dir])
    result = FCS::Benchmarking::BenchmarkRunner.new.run!(
      fixture_path: options[:fixture],
      output_dir: options[:output_dir],
      runs: options[:runs],
      command: command
    )

    report = result.fetch(:report)

    puts t("fcs.cli.bench.header")
    puts t("fcs.cli.bench.runs_line", runs: report.fetch("runs"), p95: format("%.3f", report.fetch("p95_seconds")))
    puts t("fcs.cli.bench.input_hash_line", input_hash: report.fetch("input_hash"), run_id: report.fetch("run_id"))
    puts t("fcs.cli.bench.report_line", path: result.fetch(:report_path))
    puts t("fcs.cli.bench.artifacts_line", path: report.dig("artifacts", "result_json"))
  rescue FCS::Error => e
    print_diagnostic_error(
      code: e.code,
      what_happened: e.message,
      impact: t("fcs.cli.diagnostics.bench.failure.impact"),
      next_action: t("fcs.cli.diagnostics.bench.failure.next_action"),
      details: e.details
    )
    exit(2)
  rescue StandardError => e
    print_diagnostic_error(
      code: "ERR_INTERNAL",
      what_happened: t("fcs.cli.diagnostics.bench.unexpected_error.what_happened", error_class: e.class),
      impact: t("fcs.cli.diagnostics.bench.unexpected_error.impact"),
      next_action: t("fcs.cli.diagnostics.bench.unexpected_error.next_action"),
      details: { "message" => e.message, "output_dir" => options[:output_dir] }
    )
    exit(1)
  end

when "generate-input"
  options = {
    output: "output/fcs/demo_input.json",
    tamper_output: nil,
    accounts: 2,
    markets: 2,
    trades: 24
  }

  parser = OptionParser.new do |opts|
    opts.banner = t("fcs.cli.banners.generate_input_usage")
    opts.on("--output PATH", t("fcs.cli.options.output_demo")) { |v| options[:output] = v }
    opts.on("--tamper-output PATH", t("fcs.cli.options.tamper_output")) { |v| options[:tamper_output] = v }
    opts.on("--accounts N", Integer, t("fcs.cli.options.accounts", count: options[:accounts])) { |v| options[:accounts] = v }
    opts.on("--markets N", Integer, t("fcs.cli.options.markets", count: options[:markets])) { |v| options[:markets] = v }
    opts.on("--trades N", Integer, t("fcs.cli.options.trades", count: options[:trades])) { |v| options[:trades] = v }
    opts.on("-h", "--help", t("fcs.cli.options.help")) do
      puts opts
      exit(0)
    end
  end

  begin
    parser.parse!(ARGV)
  rescue OptionParser::ParseError => e
    print_diagnostic_error(
      code: FCS::Errors::ERR_VALIDATION,
      what_happened: t("fcs.cli.diagnostics.generate_input.invalid_cli_option.what_happened"),
      impact: t("fcs.cli.diagnostics.generate_input.invalid_cli_option.impact"),
      next_action: t("fcs.cli.diagnostics.generate_input.invalid_cli_option.next_action"),
      details: { "errorClass" => e.class.name, "errorMessage" => e.message }
    )
    exit(2)
  end

  payload = build_demo_input(accounts: options[:accounts], markets: options[:markets], trades: options[:trades])
  FileUtils.mkdir_p(File.dirname(options[:output]))
  File.write(options[:output], JSON.pretty_generate(payload))
  puts t("fcs.cli.success.ok_wrote", path: options[:output])

  if options[:tamper_output]
    tampered = JSON.parse(JSON.dump(payload))
    tampered["trades"].first["priceQuotePerBase"] = "999"
    FileUtils.mkdir_p(File.dirname(options[:tamper_output]))
    File.write(options[:tamper_output], JSON.pretty_generate(tampered))
    puts t("fcs.cli.success.ok_wrote_tampered", path: options[:tamper_output])
  end

else
  puts <<~TXT
    #{t("fcs.cli.banners.usage_header")}
      #{t("fcs.cli.banners.usage_run")}
      #{t("fcs.cli.banners.usage_bench")}

    #{t("fcs.cli.banners.examples_header")}
      #{t("fcs.cli.banners.example_run")}
      #{t("fcs.cli.banners.example_run_verbose")}
      #{t("fcs.cli.banners.example_bench")}
      #{t("fcs.cli.banners.example_bench_runs")}
  TXT
  exit(1)
end
