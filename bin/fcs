#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../lib/fcs"
require "optparse"
require "json"

def print_diagnostic_error(code:, what_happened:, impact:, next_action:, details: {})
  payload = {
    "error" => {
      "code" => code,
      "message" => what_happened
    },
    "code" => code,
    "what_happened" => what_happened,
    "impact" => impact,
    "next_action" => next_action,
    "details" => details
  }

  warn(JSON.pretty_generate(payload))
end

def print_diagnostic_warning(code:, what_happened:, impact:, next_action:, details: {})
  payload = {
    "warning" => {
      "code" => code,
      "message" => what_happened
    },
    "code" => code,
    "what_happened" => what_happened,
    "impact" => impact,
    "next_action" => next_action,
    "details" => details
  }

  warn(JSON.pretty_generate(payload))
end

def required_artifact_paths(output_dir)
  {
    "result_json" => File.join(output_dir, "result.json"),
    "positions_csv" => File.join(output_dir, "positions.csv"),
    "pnl_csv" => File.join(output_dir, "pnl.csv")
  }
end

def available_artifacts(expected)
  expected.select { |_key, path| File.exist?(path) }.keys.sort
end

def failure_summary_payload
  {
    "runId" => "n/a",
    "inputHash" => "n/a",
    "schemaVersion" => "n/a",
    "engineVersion" => FCS::VERSION,
    "valuationTimestamp" => "n/a",
    "global" => {
      "realizedPnLQuote" => nil,
      "feesQuote" => nil,
      "realizedNetPnLQuote" => nil,
      "unrealizedPnLQuote" => nil,
      "totalPnLQuote" => nil,
      "totalPnLUsd" => nil
    },
    "accounts" => []
  }
end

def warn_if_unsafe_output_dir(output_dir)
  repo_root = File.expand_path("..", __dir__)
  resolved_output_dir = File.expand_path(output_dir, repo_root)
  output_root = File.expand_path("output", repo_root)
  within_output = resolved_output_dir == output_root || resolved_output_dir.start_with?(output_root + File::SEPARATOR)

  unsafe_reason = if resolved_output_dir == repo_root
    "repo_root"
  elsif !within_output
    "outside_output"
  end

  return unless unsafe_reason

  print_diagnostic_warning(
    code: "WARN_UNSAFE_OUTPUT_DIR",
    what_happened: "Output directory resolves to an unsafe path",
    impact: "Artifacts may clutter the repo root or land outside output/.",
    next_action: "Use --output-dir output/fcs or another path under output/.",
    details: {
      "output_dir" => output_dir,
      "resolved_output_dir" => resolved_output_dir,
      "repo_root" => repo_root,
      "output_root" => output_root,
      "unsafe_reason" => unsafe_reason
    }
  )
end

subcommand = ARGV.shift

case subcommand
when "run"
  options = {
    input: nil,
    output_dir: "output/fcs",
    fee_enabled: true,
    explain: false,
    verbose: false,
    quiet: true
  }

  parser = OptionParser.new do |opts|
    opts.banner = [
      "Usage: fcs run --input path/to/input.json",
      "[--output-dir output/fcs] [--no-fee] [--explain] [--verbose|--quiet]"
    ].join(" ")

    opts.on("--input PATH", "Path to input JSON (required)") { |v| options[:input] = v }
    opts.on("--output-dir DIR", "Output directory (default: output/fcs)") { |v| options[:output_dir] = v }
    opts.on("--no-fee", "Disable fee model (ignore fee fields)") { options[:fee_enabled] = false }
    opts.on("--explain", "Include explainability fields in result.json") { options[:explain] = true }
    opts.on("--verbose", "Enable detailed CLI output and summary") do
      options[:verbose] = true
      options[:quiet] = false
    end
    opts.on("--quiet", "Silence non-error output (default)") do
      options[:verbose] = false
      options[:quiet] = true
    end
    opts.on("-v", "--version", "Print version") do
      puts FCS::VERSION
      exit(0)
    end
    opts.on("-h", "--help", "Print help") do
      puts opts
      exit(0)
    end
  end

  begin
    parser.parse!(ARGV)
  rescue OptionParser::ParseError => e
    print_diagnostic_error(
      code: FCS::Errors::ERR_VALIDATION,
      what_happened: "Invalid CLI option",
      impact: "The run command arguments are invalid; execution did not start.",
      next_action: "Fix the CLI flags and re-run `bin/fcs run --help` for valid options.",
      details: { "errorClass" => e.class.name, "errorMessage" => e.message }
    )
    exit(2)
  end

  if options[:input].nil? || options[:input].strip.empty?
    print_diagnostic_error(
      code: FCS::Errors::ERR_VALIDATION,
      what_happened: "--input is required",
      impact: "The run did not start because required input path is missing.",
      next_action: "Provide `--input <path>` and retry.",
      details: { "usage" => parser.banner }
    )
    exit(2)
  end

  warn_if_unsafe_output_dir(options[:output_dir])

  unless options[:quiet]
    puts "FCS #{FCS::VERSION}"
    puts "Input: #{options[:input]}"
    puts "Output: #{options[:output_dir]}"
    puts "Fee enabled: #{options[:fee_enabled]}"
    puts "Explain: #{options[:explain]}"
    puts "Verbose: #{options[:verbose]}"
  end

  FCS.logger.level = options[:verbose] ? FCS::Logging::SimpleLogger::INFO : FCS::Logging::SimpleLogger::WARN

  begin
    runner = FCS::Application::Runner.new
    path = runner.run!(
      input_path: options[:input],
      output_dir: options[:output_dir],
      fee_enabled: options[:fee_enabled],
      explain: options[:explain],
      verbose: options[:verbose]
    )

    expected_artifacts = required_artifact_paths(options[:output_dir])
    missing_artifacts = expected_artifacts.reject { |_key, path| File.exist?(path) }
    if missing_artifacts.any?
      print_diagnostic_error(
        code: FCS::Errors::ERR_VALIDATION,
        what_happened: "Missing required artifacts after run",
        impact: "The run completed but required artifacts are missing for reproducibility checks.",
        next_action: "Inspect the output directory and re-run the command to regenerate artifacts.",
        details: {
          "missing_artifacts" => missing_artifacts,
          "expected_artifacts" => expected_artifacts
        }
      )
      exit(2)
    end

    puts "OK: wrote #{path}" unless options[:quiet]
  rescue FCS::Error => e
    expected_artifacts = required_artifact_paths(options[:output_dir])
    if options[:verbose]
      FCS::Reporting::CliSummary.new.print(
        failure_summary_payload,
        artifacts: {
          json_path: expected_artifacts["result_json"],
          positions_csv_path: expected_artifacts["positions_csv"],
          pnl_csv_path: expected_artifacts["pnl_csv"]
        },
        status: "failure",
        validate_artifacts: false
      )
    end
    details = (e.details || {}).merge(
      "run_status" => "failure",
      "output_dir" => options[:output_dir],
      "expected_artifacts" => expected_artifacts,
      "available_artifacts" => available_artifacts(expected_artifacts)
    )
    print_diagnostic_error(
      code: e.code,
      what_happened: e.message,
      impact: "The run stopped before canonical artifacts were fully produced.",
      next_action: "Fix the input/config issue and re-run `bin/fcs run --input <file> --output-dir <dir>`.",
      details: details
    )
    exit(2)
  rescue StandardError => e
    expected_artifacts = required_artifact_paths(options[:output_dir])
    if options[:verbose]
      FCS::Reporting::CliSummary.new.print(
        failure_summary_payload,
        artifacts: {
          json_path: expected_artifacts["result_json"],
          positions_csv_path: expected_artifacts["positions_csv"],
          pnl_csv_path: expected_artifacts["pnl_csv"]
        },
        status: "failure",
        validate_artifacts: false
      )
    end
    print_diagnostic_error(
      code: "ERR_INTERNAL",
      what_happened: "Unexpected runtime error: #{e.class}",
      impact: "The run failed unexpectedly and artifacts may be missing or incomplete.",
      next_action: "Retry with `--verbose`; if it persists, open an issue with this error payload.",
      details: {
        "message" => e.message,
        "run_status" => "failure",
        "output_dir" => options[:output_dir],
        "expected_artifacts" => expected_artifacts,
        "available_artifacts" => available_artifacts(expected_artifacts)
      }
    )
    exit(1)
  end

when "bench"
  options = {
    fixture: "lib/fcs/fixtures/benchmark_fixture.json",
    runs: FCS::Benchmarking::BenchmarkRunner::DEFAULT_RUNS,
    output_dir: "output/fcs/benchmarks"
  }

  parser = OptionParser.new do |opts|
    opts.banner = "Usage: fcs bench [--fixture PATH] [--runs N] [--output-dir DIR]"

    opts.on("--fixture PATH", "Path to benchmark fixture definition") { |v| options[:fixture] = v }
    opts.on("--runs N", Integer, "Number of runs for p95 (default: #{options[:runs]})") { |v| options[:runs] = v }
    opts.on("--output-dir DIR", "Benchmark output directory (default: output/fcs/benchmarks)") do |v|
      options[:output_dir] = v
    end
    opts.on("-v", "--version", "Print version") do
      puts FCS::VERSION
      exit(0)
    end
    opts.on("-h", "--help", "Print help") do
      puts opts
      exit(0)
    end
  end

  begin
    parser.parse!(ARGV)
  rescue OptionParser::ParseError => e
    print_diagnostic_error(
      code: FCS::Errors::ERR_VALIDATION,
      what_happened: "Invalid CLI option",
      impact: "The bench command arguments are invalid; execution did not start.",
      next_action: "Fix the CLI flags and re-run `bin/fcs bench --help` for valid options.",
      details: { "errorClass" => e.class.name, "errorMessage" => e.message }
    )
    exit(2)
  end

  command = "bin/fcs bench --fixture #{options[:fixture]} --runs #{options[:runs]} --output-dir #{options[:output_dir]}"

  begin
    warn_if_unsafe_output_dir(options[:output_dir])
    result = FCS::Benchmarking::BenchmarkRunner.new.run!(
      fixture_path: options[:fixture],
      output_dir: options[:output_dir],
      runs: options[:runs],
      command: command
    )

    report = result.fetch(:report)

    puts "Bench:"
    puts "  runs=#{report.fetch('runs')} p95=#{format('%.3f', report.fetch('p95_seconds'))}s"
    puts "  input_hash=#{report.fetch('input_hash')} run_id=#{report.fetch('run_id')}"
    puts "  report=#{result.fetch(:report_path)}"
    puts "  artifacts=#{report.dig('artifacts', 'result_json')}"
  rescue FCS::Error => e
    print_diagnostic_error(
      code: e.code,
      what_happened: e.message,
      impact: "The benchmark did not complete with valid evidence artifacts.",
      next_action: "Review the fixture definition and output paths, then retry.",
      details: e.details
    )
    exit(2)
  rescue StandardError => e
    print_diagnostic_error(
      code: "ERR_INTERNAL",
      what_happened: "Unexpected runtime error: #{e.class}",
      impact: "The benchmark failed unexpectedly and outputs may be incomplete.",
      next_action: "Retry with the same command; if it persists, open an issue with this error payload.",
      details: { "message" => e.message, "output_dir" => options[:output_dir] }
    )
    exit(1)
  end

else
  puts <<~TXT
    Usage:
      fcs run   --input path/to/input.json [--output-dir output/fcs] [--no-fee] [--explain] [--verbose|--quiet]
      fcs bench [--fixture PATH] [--runs N] [--output-dir DIR]

    Examples:
      fcs run --input lib/fcs/fixtures/demo_input.json --output-dir output/fcs
      fcs run --input lib/fcs/fixtures/demo_input.json --output-dir output/fcs --explain --verbose
      fcs bench
      fcs bench --runs 7 --output-dir output/fcs/benchmarks
  TXT
  exit(1)
end
