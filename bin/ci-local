#!/usr/bin/env bash
set -euo pipefail

root_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

echo "==> Root: bundle exec rspec"
(cd "$root_dir" && bundle exec rspec)

echo "==> Root: bundle exec rubocop"
(cd "$root_dir" && bundle exec rubocop)

echo "==> Root: bundle exec rubycritic lib spec --no-browser"
(cd "$root_dir" && bundle exec rubycritic lib spec --no-browser)

echo "==> Root: bundle exec bundler-audit --update"
(cd "$root_dir" && bundle exec bundler-audit --update)

echo "==> Root: bundle exec mutant"
(cd "$root_dir" && bundle exec mutant --use rspec --include lib --require ./lib/fcs --require ./spec/spec_helper -- FCS::Engine)

if [ -d "$root_dir/apps/admin" ]; then
  echo "==> Admin: install npm deps"
  (cd "$root_dir/apps/admin" && npm ci)

  echo "==> Admin: bundle exec rspec"
  (cd "$root_dir/apps/admin" && bundle exec rspec)

  echo "==> Admin: bundle exec rubocop --config .rubocop.yml"
  (cd "$root_dir/apps/admin" && bundle exec rubocop --config .rubocop.yml)

  echo "==> Admin: bundle exec brakeman --no-pager"
  (cd "$root_dir/apps/admin" && bundle exec brakeman --no-pager)
fi
