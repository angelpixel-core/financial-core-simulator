FCS_LOCALE=en

# Demo lock (PR5)
# 0 = disabled (default UX), 1 = enabled (single operator lock)
DEMO_LOCK_ENABLED=0
# TTL in seconds for lock recovery when holder disconnects
DEMO_LOCK_TTL_SECONDS=900

# Demo abuse protection (PR6)
DEMO_RATE_LIMIT_LOGIN_PER_MINUTE=10
DEMO_RATE_LIMIT_UPLOAD_PER_HOUR=24
DEMO_RATE_LIMIT_PREVIEW_PER_HOUR=60
DEMO_RATE_LIMIT_EXECUTION_PER_HOUR=40
DEMO_QUOTA_UPLOADS_PER_HOUR=12
DEMO_QUOTA_UPLOAD_VOLUME_MB_PER_DAY=200

# FX sync range controls
FX_SYNC_DEFAULT_RANGE_DAYS=30
FX_SYNC_MAX_RANGE_DAYS=90
# BCRA market open time in Argentina local time (24h)
BCRA_BANK_OPEN_HOUR_ART=10
# Max days requested per call to BCRA API (adapter chunks ranges)
BCRA_SYNC_CHUNK_DAYS=7
