<% content_for :title, "Deterministic Financial Engine" %>
<% content_for :body_class, "landing-body" %>
<div
  id="landing-react-root"
  data-demo-path="<%= @demo_path %>"
  data-source-url="<%= @source_url %>"
  data-documentation-url="<%= @documentation_url %>"
></div>
<div class="landing" data-landing-fallback>
  <div class="landing__background" aria-hidden="true">
    <span class="landing__orb landing__orb--one"></span>
    <span class="landing__orb landing__orb--two"></span>
    <span class="landing__orb landing__orb--three"></span>
  </div>
  <header class="landing__header">
    <div class="landing__header-inner">
      <a class="landing__brand" href="#top">
        <span class="landing__brand-mark">DFE</span>
        <span class="landing__brand-copy">
          <span class="landing__brand-title">Deterministic Financial Engine</span>
          <span class="landing__brand-subtitle">Audit-ready financial processing</span>
        </span>
      </a>
      <nav class="landing__nav" aria-label="Landing sections">
        <a href="#why">Why it exists</a>
        <a href="#how">How it works</a>
        <a href="#features">Features</a>
        <a href="#faq">FAQ</a>
      </nav>
      <div class="landing__header-actions">
        <a class="landing__primary-cta" href="<%= @demo_path %>">View Demo</a>
      </div>
    </div>
  </header>
  <main id="top" class="landing__main">
    <section class="landing__hero">
      <div>
        <div class="landing__eyebrow">
          <span class="landing__eyebrow-dot"></span>
          Deterministic - Event-Driven - Audit-Ready
        </div>
        <h1 class="landing__title">
          Deterministic Financial Processing.
          <span>Always the same input. Always the same output.</span>
        </h1>
        <p class="landing__subtitle">
          Validate, execute, and audit financial data pipelines with reproducible results across trades, FX, and PnL.
        </p>
        <div class="landing__hero-actions">
          <a id="demo" class="landing__primary-cta" href="<%= @demo_path %>">View Demo</a>
          <a class="landing__secondary-cta" href="#architecture">Explore Architecture</a>
        </div>
        <div class="landing__stats">
          <div class="landing__stat">
            <p class="landing__stat-title">Trades + FX</p>
            <p class="landing__stat-body">Multi-market ingestion</p>
          </div>
          <div class="landing__stat">
            <p class="landing__stat-title">Deterministic runs</p>
            <p class="landing__stat-body">Reproducible financial outputs</p>
          </div>
          <div class="landing__stat">
            <p class="landing__stat-title">Traceability</p>
            <p class="landing__stat-body">Artifacts and run history</p>
          </div>
        </div>
      </div>
      <div class="landing__hero-card">
        <div class="landing__hero-card-header">
          <div>
            <p class="landing__hero-card-eyebrow">Architecture snapshot</p>
            <p class="landing__hero-card-title">Raw inputs - trusted financial state</p>
          </div>
          <span class="landing__badge">Live concept</span>
        </div>
        <div class="landing__pipeline">
          <div class="landing__pipeline-step">
            <span class="landing__badge">1</span>
            <h3>Raw Data</h3>
            <p>Excel - API - CLI</p>
          </div>
          <div class="landing__pipeline-step">
            <span class="landing__badge">2</span>
            <h3>Validation</h3>
            <p>Rules + normalization</p>
          </div>
          <div class="landing__pipeline-step">
            <span class="landing__badge">3</span>
            <h3>Execution</h3>
            <p>Deterministic engine</p>
          </div>
          <div class="landing__pipeline-step">
            <span class="landing__badge">4</span>
            <h3>Insight</h3>
            <p>PnL - trades - trace</p>
          </div>
        </div>
        <div class="landing__metrics">
          <div class="landing__metric">
            <p class="landing__metric-label">Consistency</p>
            <p class="landing__metric-value">Same input - same output</p>
          </div>
          <div class="landing__metric">
            <p class="landing__metric-label">Failure model</p>
            <p class="landing__metric-value">Partial failure aware</p>
          </div>
          <div class="landing__metric">
            <p class="landing__metric-label">Observability</p>
            <p class="landing__metric-value">Runs, artifacts, health</p>
          </div>
        </div>
      </div>
    </section>
    <section id="why" class="landing__section">
      <div class="landing__section-header">
        <p class="landing__section-eyebrow">Why it exists</p>
        <h2 class="landing__section-title">Financial systems are hard to trust. We make them reproducible.</h2>
      </div>
      <div class="landing__why-grid">
        <div class="landing__panel">
          <p>Raw datasets often travel through fragile workflows before they reach reports, dashboards, and operational decisions.</p>
          <p>
            Deterministic Financial Engine validates, normalizes, and executes financial event streams into reproducible outputs.
            That means every run can be audited, replayed, and trusted.
          </p>
        </div>
      </div>
    </section>
    <section id="how" class="landing__section">
      <div class="landing__section-header">
        <p class="landing__section-eyebrow">How it works</p>
        <h2 class="landing__section-title">A single pipeline from ingestion to financial insight.</h2>
      </div>
      <div class="landing__how-grid">
        <div class="landing__how-step">
          <div class="landing__how-icon">1</div>
          <h3>Ingest your data</h3>
          <p>Upload trades and FX rates through CLI, API, or the web workspace.</p>
        </div>
        <div class="landing__how-step">
          <div class="landing__how-icon">2</div>
          <h3>Validate and normalize</h3>
          <p>Detect inconsistencies, standardize formats, and prepare a trustworthy execution payload.</p>
        </div>
        <div class="landing__how-step">
          <div class="landing__how-icon">3</div>
          <h3>Execute deterministically</h3>
          <p>Generate reproducible financial outputs with traceable runs, artifacts, and projections.</p>
        </div>
      </div>
    </section>
    <section id="features" class="landing__section">
      <div class="landing__section-header">
        <p class="landing__section-eyebrow">Capabilities</p>
        <h2 class="landing__section-title">Built for deterministic financial workflows.</h2>
      </div>
      <div class="landing__features-grid">
        <div class="landing__feature">
          <div class="landing__feature-bar"></div>
          <p>Deterministic execution engine</p>
        </div>
        <div class="landing__feature">
          <div class="landing__feature-bar"></div>
          <p>Partial failure handling</p>
        </div>
        <div class="landing__feature">
          <div class="landing__feature-bar"></div>
          <p>FX normalization across markets</p>
        </div>
        <div class="landing__feature">
          <div class="landing__feature-bar"></div>
          <p>Multi-account PnL computation</p>
        </div>
        <div class="landing__feature">
          <div class="landing__feature-bar"></div>
          <p>Run traceability and audit logs</p>
        </div>
        <div class="landing__feature">
          <div class="landing__feature-bar"></div>
          <p>CLI, API, and admin workspace</p>
        </div>
      </div>
    </section>
    <section id="architecture" class="landing__section">
      <div class="landing__section-header">
        <p class="landing__section-eyebrow">Architecture</p>
        <h2 class="landing__section-title">From raw trades to audit-ready financial state.</h2>
      </div>
      <div class="landing__architecture-grid">
        <div class="landing__architecture-list">
          <div class="landing__architecture-item">
            <span>0. Input Interfaces</span>
            <p>CLI - Web UI - API</p>
          </div>
          <div class="landing__architecture-item">
            <span>1. Ingestion</span>
            <p>Parser - Preview</p>
          </div>
          <div class="landing__architecture-item">
            <span>2. Validation + Normalization</span>
            <p>Validation Engine - Normalization - Hash</p>
          </div>
          <div class="landing__architecture-item">
            <span>3. Validation Result</span>
            <p>Valid / invalid outcomes</p>
          </div>
          <div class="landing__architecture-item">
            <span>4. Validation Events</span>
            <p>Event stream</p>
          </div>
          <div class="landing__architecture-item">
            <span>5. Execution</span>
            <p>Execution engine - financial projection</p>
          </div>
          <div class="landing__architecture-item">
            <span>6. Storage</span>
            <p>Data store - run storage - system health</p>
          </div>
          <div class="landing__architecture-item">
            <span>7. Workspace</span>
            <p>Admin + operator read models</p>
          </div>
        </div>
        <div class="landing__architecture-panel">
          <p class="landing__section-eyebrow">Why this matters</p>
          <h3 class="landing__section-title">A deterministic pipeline that turns untrusted financial data into reproducible outcomes.</h3>
          <p>
            Every dataset goes through parsing, validation, normalization, hashing, execution, storage, and read models before it
            reaches dashboards and operational workflows.
          </p>
          <div class="landing__stat-grid">
            <div class="landing__stat-card">
              <p class="landing__section-eyebrow">Execution model</p>
              <p>Deterministic</p>
            </div>
            <div class="landing__stat-card">
              <p class="landing__section-eyebrow">Failure strategy</p>
              <p>Partial failure aware</p>
            </div>
            <div class="landing__stat-card">
              <p class="landing__section-eyebrow">Interfaces</p>
              <p>CLI - API - Workspace</p>
            </div>
            <div class="landing__stat-card">
              <p class="landing__section-eyebrow">Outputs</p>
              <p>PnL - Trades - Traceability</p>
            </div>
          </div>
        </div>
      </div>
    </section>
    <section id="faq" class="landing__section">
      <div class="landing__section-header landing__section-header--center">
        <p class="landing__section-eyebrow">FAQ</p>
        <h2 class="landing__section-title">Questions teams ask before they trust financial outputs.</h2>
        <p class="landing__section-subtitle">Frequently asked questions</p>
      </div>
      <div class="landing__faq-stack">
        <details class="landing__faq-card">
          <summary><span class="landing__faq-question">What does deterministic mean here?</span></summary>
          <p class="landing__faq-answer">The same validated input always produces the same output. That makes runs reproducible, debuggable, and auditable.</p>
        </details>
        <details class="landing__faq-card">
          <summary><span class="landing__faq-question">What happens if a dataset contains errors?</span></summary>
          <p class="landing__faq-answer">Invalid rows are isolated and reported so you can keep visibility into failures without losing operational context.</p>
        </details>
        <details class="landing__faq-card">
          <summary><span class="landing__faq-question">Is this only for trading teams?</span></summary>
          <p class="landing__faq-answer">No. It is useful anywhere financial data must be validated before it reaches dashboards, reports, or operational decisions.</p>
        </details>
        <details class="landing__faq-card">
          <summary><span class="landing__faq-question">Can it integrate with existing systems?</span></summary>
          <p class="landing__faq-answer">Yes. The platform is designed around CLI, API, and workspace-driven ingestion so it can fit into real workflows.</p>
        </details>
      </div>
    </section>
  </main>
  <footer class="landing__footer">
    <div class="landing__footer-inner">
      <div>
        <p class="landing__footer-title">Deterministic Financial Engine</p>
        <p>
          Built to validate, execute, and audit financial event streams with reproducible outcomes across operational workflows.
        </p>
      </div>
      <div>
        <p class="landing__footer-title">Sections</p>
        <div class="landing__footer-links">
          <a href="#why">Why it exists</a>
          <a href="#how">How it works</a>
          <a href="#features">Features</a>
          <a href="#faq">FAQ</a>
        </div>
      </div>
      <div>
        <p class="landing__footer-title">Project</p>
        <div class="landing__footer-links">
          <a href="#architecture">Architecture</a>
          <a href="<%= @documentation_url %>">Documentation</a>
          <a href="<%= @source_url %>">View source</a>
        </div>
      </div>
    </div>
  </footer>
</div>
