<% content_for :title, t("admin.landing.title") %>
<% content_for :body_class, "landing-page-body" %>
<main class="landing-page">
  <section class="landing-page__hero">
    <div class="landing-page__hero-header">
      <div class="landing-page__logo">
        <%= image_tag "fcs_logo_dark_minimal_with_label.svg", alt: t("admin.landing.brand_alt") %>
      </div>
      <div class="landing-page__hero-copy">
        <p class="landing-page__eyebrow"><%= t("admin.landing.hero.eyebrow") %></p>
        <h1><%= t("admin.landing.hero.title") %></h1>
      </div>
      <div class="landing-page__locale" aria-label="<%= t("admin.common.language") %>">
        <span class="landing-page__locale-label"><%= t("admin.common.language") %></span>
        <%= link_to "EN", url_for(params: request.query_parameters.merge(locale: "en")),
          class: "landing-page__locale-link",
          "aria-current": (I18n.locale == :en ? "true" : nil) %>
        <%= link_to "ES", url_for(params: request.query_parameters.merge(locale: "es")),
          class: "landing-page__locale-link",
          "aria-current": (I18n.locale == :es ? "true" : nil) %>
      </div>
    </div>
    <p class="landing-page__subtitle">
      <%= t("admin.landing.hero.subtitle") %>
    </p>
    <div class="landing-page__cta-group">
      <a class="landing-page__cta landing-page__cta--primary" href="<%= @demo_path %>"><%= t("admin.landing.hero.cta.demo") %></a>
      <a class="landing-page__cta" href="<%= @source_url %>"><%= t("admin.landing.hero.cta.github") %></a>
      <a class="landing-page__cta" href="<%= @documentation_url %>"><%= t("admin.landing.hero.cta.documentation") %></a>
    </div>
  </section>
  <section class="landing-page__section">
    <h2><%= t("admin.landing.why.title") %></h2>
    <p class="landing-page__copy"><%= t("admin.landing.why.body") %></p>
  </section>
  <section class="landing-page__section">
    <h2><%= t("admin.landing.architecture.title") %></h2>
    <p class="landing-page__copy"><%= t("admin.landing.architecture.body") %></p>
  </section>
  <section class="landing-page__section">
    <h2><%= t("admin.landing.dashboard_preview.title") %></h2>
    <ul>
      <li><%= t("admin.landing.dashboard_preview.items.overview") %></li>
      <li><%= t("admin.landing.dashboard_preview.items.runs") %></li>
      <li><%= t("admin.landing.dashboard_preview.items.pnl") %></li>
      <li><%= t("admin.landing.dashboard_preview.items.accounts") %></li>
      <li><%= t("admin.landing.dashboard_preview.items.errors") %></li>
    </ul>
  </section>
  <section class="landing-page__section">
    <h2><%= t("admin.landing.features.title") %></h2>
    <ul>
      <li><%= t("admin.landing.features.items.deterministic_event_processing") %></li>
      <li><%= t("admin.landing.features.items.ledger_based_accounting") %></li>
      <li><%= t("admin.landing.features.items.fifo_position_engine") %></li>
      <li><%= t("admin.landing.features.items.pnl_valuation_engine") %></li>
      <li><%= t("admin.landing.features.items.multi_account_simulation") %></li>
      <li><%= t("admin.landing.features.items.audit_ready_artifacts") %></li>
    </ul>
  </section>
  <section class="landing-page__section">
    <h2><%= t("admin.landing.cli_example.title") %></h2>
    <pre><code>fcs simulate demo_input.json

runs: 14
success: 13
pnl_total: 51.00</code></pre>
  </section>
  <section class="landing-page__section">
    <h2><%= t("admin.landing.open_source.title") %></h2>
    <p class="landing-page__copy"><%= t("admin.landing.open_source.body") %></p>
    <a class="landing-page__cta" href="<%= @source_url %>"><%= t("admin.landing.open_source.cta") %></a>
  </section>
</main>
