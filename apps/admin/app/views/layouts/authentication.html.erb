<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || t("admin.auth.title") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= t("admin.auth.application_name") %>">
    <meta name="mobile-web-app-capable" content="yes">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="<%= content_for?(:body_class) ? content_for(:body_class) : "auth-page" %>">
    <main class="auth-shell" aria-label="<%= t("admin.auth.aria") %>">
      <section class="auth-hero" aria-hidden="true">
        <div class="auth-hero__copy">
          <p class="auth-hero__eyebrow"><%= t("admin.auth.hero.eyebrow") %></p>
          <h1><%= t("admin.auth.hero.title") %></h1>
          <p><%= t("admin.auth.hero.subtitle") %></p>
        </div>
      </section>
      <div class="auth-panel">
        <section class="auth-card">
          <header class="auth-card__header">
            <p class="auth-card__eyebrow"><%= t("admin.auth.card.eyebrow") %></p>
          </header>
          <div class="auth-card__content">
            <%= yield %>
          </div>
        </section>
      </div>
    </main>
    <%= yield :auth_footer if content_for?(:auth_footer) %>
  </body>
</html>
