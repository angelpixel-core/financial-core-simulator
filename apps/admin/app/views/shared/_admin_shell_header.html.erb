<header class="admin-shell-header admin-shell-header--<%= admin_shell_role %>" aria-label="<%= t("admin.shell.header_aria") %>">
  <div class="admin-shell-header__inner">
    <p class="admin-shell-header__brand"><%= admin_shell_workspace_label %></p>
    <div class="admin-shell-header__actions">
      <div class="admin-shell-header__locale" aria-label="<%= t("admin.common.language") %>">
        <span class="admin-shell-header__locale-label"><%= t("admin.common.language") %></span>
        <%= link_to "EN", url_for(params: request.query_parameters.merge(locale: "en")),
          class: "admin-shell-header__locale-link",
          "aria-current": (I18n.locale == :en ? "true" : nil) %>
        <%= link_to "ES", url_for(params: request.query_parameters.merge(locale: "es")),
          class: "admin-shell-header__locale-link",
          "aria-current": (I18n.locale == :es ? "true" : nil) %>
      </div>
      <p class="admin-shell-header__identity"><%= account_email %></p>
      <%= button_to t("admin.shell.sign_out"), logout_path, method: :post, class: "admin-shell-header__logout" %>
    </div>
  </div>
</header>
