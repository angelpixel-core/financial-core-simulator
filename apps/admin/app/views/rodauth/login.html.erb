<% login_param = rodauth.login_param %>
<% password_param = rodauth.password_param %>
<% if flash["error"].present? || flash["notice"].present? %>
  <p class="error"><%= flash["error"].presence || flash["notice"] %></p>
<% end %>
<%= form_with url: rodauth.login_path, method: :post, local: true do %>
  <div>
    <label for="admin-login-email"><%= t("admin.auth.form.email_label") %></label>
    <input
      id="admin-login-email"
      type="email"
      name="<%= login_param %>"
      value="<%= params[login_param] %>"
      autocomplete="username"
      required
    >
  </div>
  <div>
    <label for="admin-login-password"><%= t("admin.auth.form.password_label") %></label>
    <input
      id="admin-login-password"
      type="password"
      name="<%= password_param %>"
      autocomplete="current-password"
      required
    >
  </div>
  <input type="submit" value="<%= t("admin.auth.form.submit") %>">
<% end %>
<div class="auth-downloads">
  <p class="auth-downloads__title">Download test data</p>
  <div class="auth-downloads__links">
    <a class="auth-downloads__link" href="<%= demo_dataset_valid_path(locale: I18n.locale) %>">Trades (valid)</a>
    <a class="auth-downloads__link" href="<%= demo_dataset_invalid_path(locale: I18n.locale) %>">Trades (invalid)</a>
    <a class="auth-downloads__link" href="<%= template_admin_fx_rate_uploads_path(locale: I18n.locale) %>">FX rates</a>
  </div>
</div>
