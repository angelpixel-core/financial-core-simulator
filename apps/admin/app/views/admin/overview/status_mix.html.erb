<main class="overview">
  <header class="overview__header">
    <div>
      <p class="overview__eyebrow">Admin</p>
      <h1>Status Mix (30d)</h1>
      <p class="overview__subtitle">Distribution of run states over the last 30 days.</p>
    </div>
    <nav class="overview__nav">
      <a class="overview__link" href="<%= admin_overview_path %>">Back to overview</a>
      <a class="overview__link" href="<%= avo.resources_runs_path %>">Open Runs</a>
    </nav>
  </header>
  <% status_mix = @metrics[:status_mix_30d] || {} %>
  <% status_rows = [
    ["Queued", status_mix[:queued]],
    ["Running", status_mix[:running]],
    ["Succeeded", status_mix[:succeeded]],
    ["Failed", status_mix[:failed]]
  ] %>
  <%= render Admin::Ui::WorkspaceWidgetComponent.new(
    title: "Status mix (30d)",
    state: status_rows.all? { |_, value| value.nil? } ? :empty : :default,
    empty_message: "No status mix data available."
  ) do %>
    <ul class="detail-list">
      <% status_rows.each do |label, value| %>
        <li><span><%= label %></span><strong><%= value || 0 %></strong></li>
      <% end %>
    </ul>
  <% end %>
</main>
