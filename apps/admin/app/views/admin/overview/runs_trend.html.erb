<main class="overview">
  <header class="overview__header">
    <div>
      <p class="overview__eyebrow">Admin</p>
      <h1>Runs Trend (14d)</h1>
      <p class="overview__subtitle">Daily execution volume trend for the last 14 days.</p>
    </div>
    <nav class="overview__nav">
      <a class="overview__link" href="<%= admin_overview_path %>">Back to overview</a>
      <a class="overview__link" href="<%= avo.resources_runs_path %>">Open Runs</a>
    </nav>
  </header>
  <% trend_points = Array(@metrics[:runs_trend_14d]) %>
  <%= render Admin::Ui::WorkspaceWidgetComponent.new(
    title: "Run trend (14d)",
    state: trend_points.empty? ? :empty : :default,
    empty_message: "No trend points available."
  ) do %>
    <%= render Admin::Ui::WorkspaceTrendChartComponent.new(points: trend_points, detail: true) %>
  <% end %>
</main>
