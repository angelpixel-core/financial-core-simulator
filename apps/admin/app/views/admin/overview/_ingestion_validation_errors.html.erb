<article class="dashboard-card">
  <header class="dashboard-card__header">
    <h3>Ingestion validation errors</h3>
    <p class="dashboard-card__meta">Updated <%= Time.current.strftime("%H:%M:%S") %></p>
  </header>
  <form method="get" action="<%= admin_overview_ingestion_validation_errors_path %>" data-controller="ingestion-filters" data-turbo-frame="overview-ingestion-validation-errors-panel" data-action="submit->ingestion-filters#syncPollUrl" style="margin-bottom: 12px; display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
    <label for="source-filter" style="font-weight: 600;">Source</label>
    <input id="source-filter" name="source" type="text" value="<%= selected_source %>" placeholder="agente.hft.alpha" data-action="input->ingestion-filters#scheduleSubmit" style="padding: 4px 8px; border: 1px solid #cbd5e0; border-radius: 6px;" />
    <label for="field-filter" style="font-weight: 600;">Field</label>
    <input id="field-filter" name="field" type="text" value="<%= selected_field %>" placeholder="riskModel" data-action="input->ingestion-filters#scheduleSubmit" style="padding: 4px 8px; border: 1px solid #cbd5e0; border-radius: 6px;" />
    <button type="submit" style="padding: 4px 10px; border: 1px solid #1a202c; border-radius: 6px; background: #1a202c; color: #fff;">Apply</button>
    <button type="button" data-action="click->ingestion-filters#reset" style="padding: 4px 10px; border: 1px solid #cbd5e0; border-radius: 6px; color: #1a202c; background: #fff;">Reset</button>
  </form>
  <% if errors.blank? %>
    <p class="empty-state">No ingestion validation errors.</p>
  <% else %>
    <table class="top-accounts-table">
      <thead>
        <tr>
          <th>Source</th>
          <th>Field</th>
          <th>Message</th>
          <th>Occurred</th>
          <th>Correlation</th>
        </tr>
      </thead>
      <tbody>
        <% errors.each do |error| %>
          <tr>
            <td><%= error[:source] %></td>
            <td><%= error[:field] %></td>
            <td><%= error[:message] %></td>
            <td><%= error[:occurredAt] || "-" %></td>
            <td><%= error[:correlationId] || "-" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</article>
