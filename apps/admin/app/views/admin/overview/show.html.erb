<h1>Financial Overview</h1>

<section>
  <h2>Run KPIs</h2>
  <ul>
    <li>Total runs (7d): <strong><%= @metrics[:total_runs_7d] %></strong></li>
    <li>Total runs (30d): <strong><%= @metrics[:total_runs_30d] %></strong></li>
    <li>Success rate (last 50): <strong><%= @metrics[:success_rate_last_50] %>%</strong></li>
    <li>
      Avg duration (last 50 succeeded):
      <strong><%= @metrics[:avg_duration_ms_last_50].nil? ? "N/A" : "#{@metrics[:avg_duration_ms_last_50]} ms" %></strong>
    </li>
  </ul>
</section>

<section>
  <h2>Latest succeeded run</h2>
  <% if @metrics[:latest_run].nil? %>
    <p>No succeeded runs yet.</p>
  <% else %>
    <ul>
      <li>Run: <strong>#<%= @metrics[:latest_run][:id] %></strong></li>
      <li>Input hash: <code><%= @metrics[:latest_run][:input_hash] %></code></li>
      <li>Duration: <strong><%= @metrics[:latest_run][:duration_ms] %> ms</strong></li>
      <li>Schema: <strong><%= @metrics[:latest_run][:schema_version] %></strong></li>
      <li>Engine: <strong><%= @metrics[:latest_run][:engine_version] %></strong></li>
    </ul>
  <% end %>
</section>

<section>
  <h2>Global PnL (latest succeeded run)</h2>
  <% if @metrics[:latest_global].nil? %>
    <p>Global totals unavailable (missing or invalid result.json).</p>
  <% else %>
    <ul>
      <li>Total: <strong><%= @metrics[:latest_global]["totalPnLQuote"] %></strong></li>
      <li>Realized net: <strong><%= @metrics[:latest_global]["realizedNetPnLQuote"] %></strong></li>
      <li>Unrealized: <strong><%= @metrics[:latest_global]["unrealizedPnLQuote"] %></strong></li>
      <li>Total USD: <strong><%= @metrics[:latest_global]["totalPnLUsd"] || "N/A" %></strong></li>
    </ul>
  <% end %>
</section>

<section>
  <h2>Top accounts (latest succeeded run)</h2>
  <% if @metrics[:top_accounts].empty? %>
    <p>No account totals available.</p>
  <% else %>
    <table>
      <thead>
        <tr>
          <th>Account</th>
          <th>Total PnL Quote</th>
          <th>Realized Net</th>
          <th>Unrealized</th>
        </tr>
      </thead>
      <tbody>
        <% @metrics[:top_accounts].each do |account| %>
          <tr>
            <td><%= account[:account_id] %></td>
            <td><%= account[:total_pnl_quote].to_s("F") %></td>
            <td><%= account[:realized_net_pnl_quote].to_s("F") %></td>
            <td><%= account[:unrealized_pnl_quote].to_s("F") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</section>
