<h1>Component Comparison: ViewComponent vs Phlex</h1>
<p>
  <a href="<%= admin_overview_path %>">Back to S7.3 overview</a>
</p>
<section>
  <h2>Same input data, two implementations</h2>
  <%= render Admin::Cards::ViewComponentMetricCardComponent.new(
    title: @card_title,
    value: @card_value,
    info: @card_info
  ) %>
  <%= render Admin::Cards::PhlexMetricCard.new(
    title: @card_title,
    value: @card_value,
    info: @card_info
  ) %>
</section>
<section>
  <h2>Decision checklist</h2>
  <ul>
    <li>Readability for team: ERB sidecar (ViewComponent) vs Ruby DSL (Phlex)</li>
    <li>Testing style: DOM matcher style (ViewComponent) vs object rendering style (Phlex)</li>
    <li>Performance sensitivity: moderate pages vs heavy component trees</li>
    <li>Long-term consistency with existing Rails conventions</li>
  </ul>
</section>
<section>
  <h2>Drilldown state coverage</h2>
  <h3>DataTable: default</h3>
  <%= render Admin::Ui::DataTableComponent.new(
    columns: [
      { key: :account, label: "Account" },
      { key: :total_pnl_quote, label: "Total PnL Quote" }
    ],
    rows: [
      { account: "acc-1", total_pnl_quote: "125.50" }
    ]
  ) %>
  <h3>DataTable: loading</h3>
  <%= render Admin::Ui::DataTableComponent.new(
    columns: [
      { key: :account, label: "Account" },
      { key: :total_pnl_quote, label: "Total PnL Quote" }
    ],
    rows: [],
    state: :loading
  ) %>
  <h3>EmptyState: empty</h3>
  <%= render Admin::Ui::EmptyStateComponent.new(
    message: "No account totals available."
  ) %>
  <h3>EmptyState: error</h3>
  <%= render Admin::Ui::EmptyStateComponent.new(
    title: "Source degraded",
    message: "Dashboard source unavailable.",
    icon: "!",
    tone: :error
  ) %>
</section>
