<% navigation_context = @navigation_context || {} %>
<% shell_role = admin_shell_role %>
<% secondary_action = nil %>
<% sidebar_items = [
  { label: t("admin.nav.overview"), path: admin_overview_path(navigation_context), active: false, icon_key: "overview", external: false }
] %>
<% sidebar_items << { label: t("admin.nav.history"), path: admin_fx_history_index_path(navigation_context), active: true, icon_key: "dollar", external: false } %>
<% sidebar_items << { label: t("admin.nav.observability"), path: admin_fx_observability_path(navigation_context), active: false, icon_key: "layout-dashboard", external: false } %>
<% runs_item = { label: t("admin.nav.runs"), path: admin_system_health_path(navigation_context), active: false, icon_key: "runs", external: false } %>
<% runs_item[:icon_variant] = "sensitive" if shell_role == "admin" %>
<% sidebar_items << runs_item %>
<% if admin_shell_admin? %>
  <% sidebar_items << { label: t("admin.nav.support"), path: Avo.configuration.root_path, active: false, icon_key: "support", external: false } %>
<% end %>
<%= render Admin::Shell::AppShellComponent.new(
  sidebar_items: sidebar_items,
  breadcrumb: [
    { label: t("admin.nav.workspace"), path: admin_overview_path(navigation_context) },
    { label: t("admin.fx.history.title") }
  ],
  environment: nil,
  presence_email: admin_shell_account_email,
  primary_action: nil,
  secondary_action: secondary_action,
  right_panel: {
    label: t("admin.fx.history.events.panel_title"),
    panel_id: "fx-events-panel"
  }
) do %>
  <main class="workspace fx-history-page">
    <section class="workspace__hero fx-history-hero">
      <div class="workspace__intro fx-history-hero__intro">
        <p class="workspace__eyebrow"><%= t("admin.nav.workspace") %></p>
        <h1><%= t("admin.fx.history.title") %></h1>
        <p class="workspace__subtitle"><%= t("admin.fx.history.subtitle") %></p>
      </div>
      <% if admin_shell_operator? || admin_shell_admin? %>
        <div class="fx-history-hero__upload">
          <% if @upload_status_stream.present? %>
            <%= turbo_stream_from @upload_status_stream %>
          <% end %>
          <section class="dashboard-card fx-history-upload">
            <header class="dashboard-card__header">
              <h2><%= t("admin.fx.history.upload.title") %></h2>
            </header>
            <div class="demo-dataset-preview" data-controller="fx--upload-preview">
              <%= form_with url: admin_fx_rate_uploads_path(locale: I18n.locale),
                          method: :post,
                          multipart: true,
                          local: true,
                          class: "fx-history-upload__form",
                          data: {
                            action: "turbo:submit-start->fx--upload-preview#start turbo:submit-end->fx--upload-preview#finish turbo:submit-end->fx--upload-actions#onSubmitEnd fx-rate-upload:clear-file@window->fx--upload-actions#clearFile",
                            controller: "fx--upload-actions",
                            "fx--upload-actions-default-icon-value": asset_path("icons/xls.svg"),
                            "fx--upload-actions-ready-icon-value": asset_path("icons/review.svg")
                          } do |form| %>
                <%= hidden_field_tag :locale, I18n.locale %>
                <div class="fx-history-upload__row">
                  <%= form.label :file, t("admin.fx.history.upload.subtitle"), class: "fx-history-upload__label" %>
                  <div class="fx-history-upload__actions">
                    <%= form.file_field :file,
                    accept: ".xlsx",
                    class: "overview__dataset-file-input",
                    id: "fx-history-upload-file",
                    data: {
                      "fx--upload-actions-target": "fileInput",
                      action: "change->fx--upload-actions#onFileChange"
                    } %>
                    <button type="button" class="overview__icon-button" title="<%= t("admin.fx.history.upload.subtitle") %>" aria-label="<%= t("admin.fx.history.upload.subtitle") %>" data-action="click->fx--upload-actions#handleReviewClick">
                      <%= image_tag("icons/xls.svg", class: "overview__icon", alt: "", data: { "fx--upload-actions-target": "fileIcon" }) %>
                    </button>
                    <button class="overview__icon-button overview__icon-button--primary" type="submit" title="<%= t("admin.fx.history.upload.cta") %>" aria-label="<%= t("admin.fx.history.upload.cta") %>" disabled data-fx--upload-actions-target="submitButton">
                      <%= image_tag("icons/play.svg", class: "overview__icon", alt: "") %>
                    </button>
                    <button type="submit" hidden data-fx--upload-actions-target="previewSubmit" data-fx-rate-upload-preview-submit="true" formaction="<%= preview_admin_fx_rate_uploads_path(locale: I18n.locale) %>" formmethod="post" data-turbo-frame="fx-rate-upload-preview"></button>
                  </div>
                  <p class="fx-history-upload__hint"><%= t("admin.fx.history.upload.hint") %></p>
                </div>
              <% end %>
              <%= button_to clear_admin_fx_rate_uploads_path(locale: I18n.locale), method: :post, class: "overview__icon-button overview__icon-button--danger", title: t("admin.fx.history.upload.clear_cta"), form: { class: "overview__dataset-reset", data: { turbo_confirm: t("admin.fx.history.upload.clear_confirm") } }, aria: { label: t("admin.fx.history.upload.clear_cta") } do %>
                <%= image_tag("icons/trash.svg", class: "overview__icon", alt: "") %>
              <% end %>
              <%= turbo_frame_tag "fx-rate-upload-preview",
              class: "demo-dataset-preview__frame",
              data: {
                action: "turbo:frame-load->fx--upload-preview#open",
                "fx--upload-preview-target": "frame",
                loading_label: t("admin.fx.history.upload.preview.loading")
              } %>
            </div>
            <%= render "admin/fx/history/upload_status", upload: @latest_upload %>
            <div class="fx-history-upload__sync-row">
              <%= form_with url: admin_fx_history_index_path(navigation_context),
                            method: :get,
                            local: true,
                            class: "fx-history-upload__source-form",
                            data: { controller: "auto-submit" } do |form| %>
                <%= hidden_field_tag :sort, @sort_order if @sort_order.present? %>
                <div class="fx-history-upload__source-row">
                  <%= form.label :source_id, t("admin.fx.history.sync.select_source_hint"), class: "fx-history-sync__label" %>
                  <%= form.select :source_id,
                    [[t("admin.fx.history.filter.all_sources"), ""]] + @fx_sources.map { |source| [source.name, source.id] },
                    { selected: @selected_source&.id },
                    class: "fx-history-hero__filter-select",
                    data: { action: "change->auto-submit#submit" } %>
                </div>
              <% end %>
              <%= render "admin/fx/history/sync_panel",
                selected_source: @selected_source %>
            </div>
          </section>
        </div>
      <% end %>
    </section>
    <section class="workspace__overview">
      <%= render "admin/fx/history/history_table",
        dates: @dates,
        supported_pairs: @supported_pairs,
        rates_by_pair: @rates_by_pair,
        role: shell_role,
        sort_order: @sort_order,
        navigation_context: navigation_context,
        empty_history: @empty_history,
        selected_source: @selected_source,
        rate_lineage: @rate_lineage %>
    </section>
  </main>
  <aside id="fx-events-panel" class="fx-events-panel" data-fx--right-panel-target="panel" hidden>
    <div class="fx-events-panel__overlay" data-action="click->fx--right-panel#close"></div>
    <section class="fx-events-panel__drawer" role="dialog" aria-modal="true">
      <header class="fx-events-panel__header">
        <div>
          <p class="fx-events-panel__eyebrow"><%= t("admin.fx.history.events.panel_label") %></p>
          <h3 class="fx-events-panel__title"><%= t("admin.fx.history.events.panel_title") %></h3>
        </div>
        <button type="button" class="fx-events-panel__close" data-action="click->fx--right-panel#close">×</button>
      </header>
      <div class="fx-events-panel__body">
        <%= render "admin/fx/history/recent_events", events: @recent_events, compact: true %>
      </div>
      <footer class="fx-events-panel__footer">
        <% if shell_role != "operator" %>
          <a class="fx-events-panel__link" href="<%= avo.resources_runs_path %>"><%= t("admin.nav.open_runs") %></a>
        <% end %>
      </footer>
    </section>
  </aside>
<% end %>
