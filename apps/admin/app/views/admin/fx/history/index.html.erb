<% navigation_context = @navigation_context || {} %>
<% shell_role = admin_shell_role %>
<% secondary_action = shell_role == "operator" ? nil : { label: t("admin.nav.open_runs"), path: avo.resources_runs_path } %>
<% artifacts_path = main_app.run_latest_result_path(navigation_context) %>
<% sidebar_items = [
  { label: t("admin.nav.overview"), path: admin_overview_path(navigation_context), active: false, icon_key: "overview", external: false }
] %>
<% runs_item = { label: t("admin.nav.runs"), path: admin_system_health_path(navigation_context), active: false, icon_key: "runs", external: false } %>
<% runs_item[:icon_variant] = "sensitive" if shell_role == "admin" %>
<% sidebar_items << runs_item %>
<% sidebar_items << { label: t("admin.nav.history"), path: admin_fx_history_index_path(navigation_context), active: true, icon_key: "history", external: false } %>
<% sidebar_items.concat([
  { label: t("admin.nav.validation"), path: admin_overview_ingestion_validation_errors_path(navigation_context), active: false, icon_key: "validation", external: false },
  { label: t("admin.nav.artifacts"), path: artifacts_path, active: false, icon_key: "artifacts", external: false },
  { label: t("admin.nav.docs"), path: admin_docs_path(navigation_context), active: false, icon_key: "docs", external: false }
]) %>
<% if admin_shell_admin? %>
  <% sidebar_items << { label: t("admin.nav.support"), path: Avo.configuration.root_path, active: false, icon_key: "support", external: false } %>
<% end %>
<%= render Admin::Shell::AppShellComponent.new(
  sidebar_items: sidebar_items,
  topbar_links: [
    { label: t("admin.nav.docs"), path: admin_docs_path(navigation_context) }
  ],
  breadcrumb: [
    { label: t("admin.nav.workspace"), path: admin_overview_path(navigation_context) },
    { label: t("admin.fx.history.title") }
  ],
  environment: nil,
  presence_email: admin_shell_account_email,
  primary_action: nil,
  secondary_action: secondary_action
) do %>
  <main class="workspace fx-history-page">
    <section class="workspace__hero">
      <div class="workspace__intro">
        <p class="workspace__eyebrow"><%= t("admin.nav.workspace") %></p>
        <h1><%= t("admin.fx.history.title") %></h1>
        <p class="workspace__subtitle"><%= t("admin.fx.history.subtitle") %></p>
      </div>
    </section>
    <section class="workspace__overview">
      <% if admin_shell_operator? || admin_shell_admin? %>
        <%= turbo_stream_from @upload_status_stream %>
        <section class="dashboard-card fx-history-upload">
          <header class="dashboard-card__header">
            <h2><%= t("admin.fx.history.upload.title") %></h2>
            <p class="dashboard-card__meta"><%= t("admin.fx.history.upload.subtitle") %></p>
          </header>
          <%= form_with url: admin_fx_rate_uploads_path(locale: I18n.locale),
                        method: :post,
                        multipart: true,
                        local: true,
                        class: "fx-history-upload__form",
                        data: { controller: "auto-submit" } do |form| %>
            <%= hidden_field_tag :locale, I18n.locale %>
            <div class="fx-history-upload__row">
              <%= form.file_field :file,
                accept: ".xlsx",
                class: "fx-history-upload__file",
                data: { action: "change->auto-submit#submit" } %>
              <%= form.submit t("admin.fx.history.upload.cta"), class: "fx-history-upload__button" %>
            </div>
            <p class="fx-history-upload__hint"><%= t("admin.fx.history.upload.hint") %></p>
          <% end %>
          <%= render "admin/fx/history/upload_status", upload: @latest_upload %>
        </section>
      <% end %>
      <% if @empty_history %>
        <section class="dashboard-card">
          <p class="empty-state"><%= t("admin.fx.history.empty") %></p>
        </section>
      <% else %>
        <section class="fx-history-grid">
          <% @pair_entries.each do |entry| %>
            <%= render Admin::Fx::HistoryListComponent.new(
              base_currency: entry[:base_currency],
              quote_currency: entry[:quote_currency],
              entries: entry[:entries],
              role: shell_role
            ) %>
          <% end %>
        </section>
      <% end %>
    </section>
  </main>
<% end %>
