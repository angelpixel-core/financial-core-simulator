<section class="dashboard-card fx-history-sync-panel">
  <header class="dashboard-card__header">
    <h2><%= t("admin.fx.history.sync.title") %></h2>
    <p class="dashboard-card__meta"><%= t("admin.fx.history.sync.subtitle") %></p>
  </header>
  <%= form_with url: sync_admin_fx_ingestions_path(locale: I18n.locale), method: :post, local: false,
    class: "fx-history-sync__form" do |form| %>
    <%= hidden_field_tag :locale, I18n.locale %>
    <div class="fx-history-sync__row">
      <span class="fx-history-sync__label"><%= t("admin.fx.history.sync.source_label") %></span>
      <% if selected_source.present? %>
        <strong class="fx-history-sync__value"><%= selected_source.name %></strong>
        <%= form.hidden_field :source_id, value: selected_source.id %>
      <% else %>
        <strong class="fx-history-sync__value"><%= t("admin.fx.history.filter.all_sources") %></strong>
      <% end %>
    </div>
    <%= form.submit t("admin.fx.history.sync.cta"),
      class: "fx-history-sync__cta",
      disabled: selected_source.blank? %>
    <% if selected_source.blank? %>
      <p class="fx-history-sync__hint"><%= t("admin.fx.history.sync.select_source_hint") %></p>
    <% end %>
  <% end %>
  <div id="fx-ingestion-status">
    <%= render "admin/fx/history/ingestion_status",
      fx_sources: fx_sources,
      latest_ingestions: latest_ingestions,
      selected_source: selected_source %>
  </div>
</section>
