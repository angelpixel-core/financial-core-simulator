<% compact = local_assigns.fetch(:compact, false) %>
<% pagination = local_assigns[:pagination] %>
<% navigation_context = local_assigns.fetch(:navigation_context, {}) %>
<section class="<%= compact ? "fx-history-events fx-history-events--compact" : "dashboard-card fx-history-events" %>">
  <% unless compact %>
    <header class="dashboard-card__header">
      <h2><%= t("admin.fx.history.events.title") %></h2>
      <p class="dashboard-card__meta"><%= t("admin.fx.history.events.subtitle") %></p>
    </header>
  <% end %>
  <div id="fx-recent-events">
    <% if events.blank? %>
      <p class="fx-history-events__empty"><%= t("admin.fx.history.events.empty") %></p>
    <% else %>
      <ul class="fx-history-events__list">
        <% events.each do |event| %>
          <li class="fx-history-events__item">
            <div>
              <span class="fx-history-events__type"><%= event.event_type %></span>
              <% if event.data["error_code"].present? %>
                <span class="fx-history-events__error"><%= event.data["error_code"] %></span>
              <% end %>
              <% if event.data["user_message_key"].present? %>
                <span class="fx-history-events__error"><%= t(event.data["user_message_key"], default: event.data["user_message_key"]) %></span>
              <% elsif event.data["user_message"].present? %>
                <span class="fx-history-events__error"><%= event.data["user_message"] %></span>
              <% end %>
              <% if event.data["action_hint_key"].present? %>
                <span class="fx-history-events__error"><%= t(event.data["action_hint_key"], default: event.data["action_hint_key"]) %></span>
              <% elsif event.data["action_hint"].present? %>
                <span class="fx-history-events__error"><%= event.data["action_hint"] %></span>
              <% end %>
            </div>
            <time class="fx-history-events__time"><%= l(event.created_at, format: :short) %></time>
          </li>
        <% end %>
      </ul>
      <% if pagination && pagination[:total_pages] > 1 %>
        <nav class="pagination pagination--pnl" aria-label="<%= t("admin.fx.history.events.pagination_aria") %>">
          <ul class="pagination-content">
            <li class="pagination-item">
              <% if pagination[:page] > 1 %>
                <%= link_to admin_fx_history_index_path(navigation_context.merge(events_page: pagination[:page] - 1)), class: "pagination-link pagination-prev" do %>
                  <span aria-hidden="true">‹</span>
                  <span class="pagination-text"><%= t("admin.common.previous") %></span>
                <% end %>
              <% else %>
                <span class="pagination-link pagination-prev pagination-disabled">
                  <span aria-hidden="true">‹</span>
                  <span class="pagination-text"><%= t("admin.common.previous") %></span>
                </span>
              <% end %>
            </li>
            <% total_pages = pagination[:total_pages] %>
            <% current_page = pagination[:page] %>
            <% (1..total_pages).each do |page_number| %>
              <li class="pagination-item">
                <%= link_to page_number, admin_fx_history_index_path(navigation_context.merge(events_page: page_number)), class: "pagination-link#{" is-active" if page_number == current_page}" %>
              </li>
            <% end %>
            <li class="pagination-item">
              <% if pagination[:page] < pagination[:total_pages] %>
                <%= link_to admin_fx_history_index_path(navigation_context.merge(events_page: pagination[:page] + 1)), class: "pagination-link pagination-next" do %>
                  <span class="pagination-text"><%= t("admin.common.next") %></span>
                  <span aria-hidden="true">›</span>
                <% end %>
              <% else %>
                <span class="pagination-link pagination-next pagination-disabled">
                  <span class="pagination-text"><%= t("admin.common.next") %></span>
                  <span aria-hidden="true">›</span>
                </span>
              <% end %>
            </li>
          </ul>
        </nav>
      <% end %>
    <% end %>
  </div>
</section>
