<% navigation_context = @navigation_context || {} %>
<% shell_role = admin_shell_role %>
<% secondary_action = shell_role == "operator" ? nil : { label: t("admin.nav.open_runs"), path: avo.resources_runs_path } %>
<% sidebar_items = [
  { label: t("admin.nav.overview"), path: admin_overview_path(navigation_context), active: false, icon_key: "overview", external: false }
] %>
<% sidebar_items << { label: t("admin.nav.history"), path: admin_fx_history_index_path(navigation_context), active: false, icon_key: "dollar", external: false } %>
<% sidebar_items << { label: t("admin.nav.observability"), path: admin_fx_observability_path(navigation_context), active: true, icon_key: "layout-dashboard", external: false } %>
<% runs_item = { label: t("admin.nav.runs"), path: admin_system_health_path(navigation_context), active: false, icon_key: "runs", external: false } %>
<% runs_item[:icon_variant] = "sensitive" if shell_role == "admin" %>
<% sidebar_items << runs_item %>
<% if admin_shell_admin? %>
  <% sidebar_items << { label: t("admin.nav.support"), path: Avo.configuration.root_path, active: false, icon_key: "support", external: false } %>
<% end %>
<%= render Admin::Shell::AppShellComponent.new(
  sidebar_items: sidebar_items,
  breadcrumb: [
    { label: t("admin.nav.workspace"), path: admin_overview_path(navigation_context) },
    { label: t("admin.nav.observability") }
  ],
  environment: nil,
  presence_email: admin_shell_account_email,
  primary_action: nil,
  secondary_action: secondary_action
) do %>
  <main class="workspace fx-observability-page">
    <section class="workspace__hero fx-observability-hero">
      <div class="workspace__intro fx-observability-hero__intro">
        <p class="workspace__eyebrow"><%= t("admin.nav.workspace") %></p>
        <h1><%= t("admin.fx.observability.title") %></h1>
        <p class="workspace__subtitle"><%= t("admin.fx.observability.subtitle") %></p>
        <%= form_with url: admin_fx_observability_path(navigation_context),
                      method: :get,
                      local: true,
                      class: "fx-observability-hero__filter",
                      data: { controller: "auto-submit" } do |form| %>
          <div class="fx-observability-hero__filter-row">
            <%= form.label :source_id, t("admin.fx.observability.filter.label") %>
            <%= form.select :source_id,
              [[t("admin.fx.observability.filter.all_sources"), ""]] + @fx_sources.map { |source| [source.name, source.id] },
              { selected: @selected_source&.id },
              class: "fx-observability-hero__filter-select",
              data: { action: "change->auto-submit#submit" } %>
          </div>
          <div class="fx-observability-hero__filter-row">
            <%= form.label :days, t("admin.fx.observability.filter.range_label") %>
            <%= form.select :days,
              [
                [t("admin.fx.observability.filter.range_7d"), 7],
                [t("admin.fx.observability.filter.range_14d"), 14],
                [t("admin.fx.observability.filter.range_30d"), 30]
              ],
              { selected: @days },
              class: "fx-observability-hero__filter-select",
              data: { action: "change->auto-submit#submit" } %>
          </div>
        <% end %>
      </div>
    </section>
    <% summary = @snapshot.fetch(:summary) %>
    <% range = @snapshot.fetch(:range) %>
    <% sources = @snapshot.fetch(:sources) %>
    <% counts_by_source = @snapshot.fetch(:counts_by_source_totals, []) %>
    <% failures_by_code = @snapshot.fetch(:failures_by_code_totals, []) %>
    <% events = @snapshot.fetch(:events) %>
    <% success_failure_points = counts_by_source.map do |source|
      {
        label: source[:source_name],
        success: source[:success],
        failed: source[:failed]
      }
    end %>
    <% failures_points = failures_by_code.map do |failure|
      {
        label: failure[:error_code] || t("admin.fx.observability.failures.unknown"),
        count: failure[:count]
      }
    end %>
    <section class="workspace__overview">
      <section class="overview__domain" aria-label="<%= t("admin.fx.observability.summary.title") %>">
        <h2 class="overview__domain-title"><%= t("admin.fx.observability.summary.title") %></h2>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2><%= t("admin.fx.observability.summary.title") %></h2>
            <p class="dashboard-card__meta"><%= t("admin.fx.observability.range", from: range[:from], to: range[:to]) %></p>
          </header>
          <ul class="detail-list">
            <li>
              <span><%= t("admin.fx.observability.summary.total") %></span>
              <strong><%= summary[:total] %></strong>
            </li>
            <li>
              <span><%= t("admin.fx.observability.summary.success") %></span>
              <strong><%= summary[:success] %></strong>
            </li>
            <li>
              <span><%= t("admin.fx.observability.summary.failed") %></span>
              <strong><%= summary[:failed] %></strong>
            </li>
            <li>
              <span><%= t("admin.fx.observability.summary.running") %></span>
              <strong><%= summary[:running] %></strong>
            </li>
            <li>
              <span><%= t("admin.fx.observability.summary.pending") %></span>
              <strong><%= summary[:pending] %></strong>
            </li>
          </ul>
        </section>
      </section>
      <section class="overview__domain" aria-label="<%= t("admin.fx.observability.charts.success_vs_failure.title") %>">
        <h2 class="overview__domain-title"><%= t("admin.fx.observability.charts.success_vs_failure.title") %></h2>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2><%= t("admin.fx.observability.charts.success_vs_failure.title") %></h2>
          </header>
          <div
            data-controller="fx--observability--chart"
            data-fx--observability--chart-title-value="<%= t("admin.fx.observability.charts.success_vs_failure.title") %>"
            data-fx--observability--chart-x-key-value="label"
            data-fx--observability--chart-tooltip-label-value="<%= t("admin.fx.observability.charts.success_vs_failure.tooltip_label") %>"
            data-fx--observability--chart-points-value="<%= success_failure_points.to_json %>"
            data-fx--observability--chart-series-value="<%= [
              { key: "success", label: t("admin.fx.observability.charts.success_vs_failure.success_label"), color: "#22c55e" },
              { key: "failed", label: t("admin.fx.observability.charts.success_vs_failure.failed_label"), color: "#f87171" }
            ].to_json %>"
          >
            <div class="trend-chart" data-fx--observability--chart-target="chart" aria-label="<%= t("admin.fx.observability.charts.success_vs_failure.title") %>"></div>
            <ul class="trend-line-fallback" data-fx--observability--chart-target="fallback">
              <% success_failure_points.each do |point| %>
                <li>
                  <span><%= point[:label] %></span>
                  <strong><%= t("admin.fx.observability.charts.success_vs_failure.success_label") %>: <%= point[:success] %> · <%= t("admin.fx.observability.charts.success_vs_failure.failed_label") %>: <%= point[:failed] %></strong>
                </li>
              <% end %>
            </ul>
          </div>
        </section>
      </section>
      <section class="overview__domain" aria-label="<%= t("admin.fx.observability.charts.failures_by_code.title") %>">
        <h2 class="overview__domain-title"><%= t("admin.fx.observability.charts.failures_by_code.title") %></h2>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2><%= t("admin.fx.observability.charts.failures_by_code.title") %></h2>
          </header>
          <div
            data-controller="fx--observability--chart"
            data-fx--observability--chart-title-value="<%= t("admin.fx.observability.charts.failures_by_code.title") %>"
            data-fx--observability--chart-x-key-value="label"
            data-fx--observability--chart-tooltip-label-value="<%= t("admin.fx.observability.charts.failures_by_code.tooltip_label") %>"
            data-fx--observability--chart-points-value="<%= failures_points.to_json %>"
            data-fx--observability--chart-series-value="<%= [
              { key: "count", label: t("admin.fx.observability.charts.failures_by_code.count_label"), color: "#38bdf8" }
            ].to_json %>"
          >
            <div class="trend-chart" data-fx--observability--chart-target="chart" aria-label="<%= t("admin.fx.observability.charts.failures_by_code.title") %>"></div>
            <ul class="trend-line-fallback" data-fx--observability--chart-target="fallback">
              <% failures_points.each do |point| %>
                <li>
                  <span><%= point[:label] %></span>
                  <strong><%= point[:count] %></strong>
                </li>
              <% end %>
            </ul>
          </div>
        </section>
      </section>
      <section class="overview__domain" aria-label="<%= t("admin.fx.observability.sources.title") %>">
        <h2 class="overview__domain-title"><%= t("admin.fx.observability.sources.title") %></h2>
        <%= render Admin::Ui::WorkspaceWidgetComponent.new(
          title: t("admin.fx.observability.sources.title"),
          state: sources.empty? ? :empty : :default,
          empty_message: t("admin.fx.observability.empty")
        ) do %>
          <%= render Admin::Ui::WorkspaceTableAdapterComponent.new(
            columns: [
              { key: :source, label: t("admin.fx.observability.sources.columns.source") },
              { key: :status, label: t("admin.fx.observability.sources.columns.status") },
              { key: :error_code, label: t("admin.fx.observability.sources.columns.error_code") },
              { key: :updated_at, label: t("admin.fx.observability.sources.columns.updated_at") }
            ],
            rows: sources.map do |source|
              {
                source: source[:source_name],
                status: t("admin.fx.observability.status.#{source[:status] || "none"}"),
                error_code: source[:error_code] || t("admin.common.na"),
                updated_at: source[:updated_at] || t("admin.common.na")
              }
            end,
            table_class: "top-accounts-table table--striped"
          ) %>
        <% end %>
      </section>
      <section class="overview__domain" aria-label="<%= t("admin.fx.observability.counts.title") %>">
        <h2 class="overview__domain-title"><%= t("admin.fx.observability.counts.title") %></h2>
        <%= render Admin::Ui::WorkspaceWidgetComponent.new(
          title: t("admin.fx.observability.counts.title"),
          state: counts_by_source.empty? ? :empty : :default,
          empty_message: t("admin.fx.observability.empty")
        ) do %>
          <%= render Admin::Ui::WorkspaceTableAdapterComponent.new(
            columns: [
              { key: :source, label: t("admin.fx.observability.counts.columns.source") },
              { key: :success, label: t("admin.fx.observability.counts.columns.success") },
              { key: :failed, label: t("admin.fx.observability.counts.columns.failed") },
              { key: :running, label: t("admin.fx.observability.counts.columns.running") },
              { key: :pending, label: t("admin.fx.observability.counts.columns.pending") }
            ],
            rows: counts_by_source.map do |source|
              {
                source: source[:source_name],
                success: source[:success],
                failed: source[:failed],
                running: source[:running],
                pending: source[:pending]
              }
            end,
            table_class: "top-accounts-table table--striped"
          ) %>
        <% end %>
      </section>
      <section class="overview__domain" aria-label="<%= t("admin.fx.observability.failures.title") %>">
        <h2 class="overview__domain-title"><%= t("admin.fx.observability.failures.title") %></h2>
        <%= render Admin::Ui::WorkspaceWidgetComponent.new(
          title: t("admin.fx.observability.failures.title"),
          state: failures_by_code.empty? ? :empty : :default,
          empty_message: t("admin.fx.observability.empty")
        ) do %>
          <%= render Admin::Ui::WorkspaceTableAdapterComponent.new(
            columns: [
              { key: :error_code, label: t("admin.fx.observability.failures.columns.error_code") },
              { key: :severity, label: t("admin.fx.observability.failures.columns.severity") },
              { key: :count, label: t("admin.fx.observability.failures.columns.count") }
            ],
            rows: failures_by_code.map do |failure|
              {
                error_code: failure[:error_code] || t("admin.common.na"),
                severity: failure[:severity] || t("admin.common.na"),
                count: failure[:count]
              }
            end,
            table_class: "top-accounts-table table--striped"
          ) %>
        <% end %>
      </section>
      <section class="overview__domain" aria-label="<%= t("admin.fx.observability.events.title") %>">
        <h2 class="overview__domain-title"><%= t("admin.fx.observability.events.title") %></h2>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2><%= t("admin.fx.observability.events.title") %></h2>
          </header>
          <% if events.blank? %>
            <p class="empty-state"><%= t("admin.fx.observability.events.empty") %></p>
          <% else %>
            <ol class="fx-observability-timeline">
              <% events.each do |event| %>
                <li class="fx-observability-timeline__item">
                  <div class="fx-observability-timeline__meta">
                    <p class="fx-observability-timeline__type"><%= event[:event_type] %></p>
                    <p class="fx-observability-timeline__time"><%= event[:created_at] %></p>
                  </div>
                  <div class="fx-observability-timeline__details">
                    <span><%= t("admin.fx.observability.events.source") %>: <%= event[:source_code] || event[:source_id] || t("admin.common.na") %></span>
                    <span><%= t("admin.fx.observability.events.ingestion") %>: <%= event[:ingestion_id] || t("admin.common.na") %></span>
                    <span><%= t("admin.fx.observability.events.error_code") %>: <%= event[:error_code] || t("admin.common.na") %></span>
                    <span><%= t("admin.fx.observability.events.severity") %>: <%= event[:severity] || t("admin.common.na") %></span>
                  </div>
                </li>
              <% end %>
            </ol>
          <% end %>
        </section>
      </section>
    </section>
  </main>
<% end %>
