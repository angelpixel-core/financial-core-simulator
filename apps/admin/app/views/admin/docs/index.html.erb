<% navigation_context = @navigation_context || {} %>
<% shell_role = admin_shell_role %>
<% secondary_action = shell_role == "operator" ? nil : { label: t("admin.nav.open_runs"), path: avo.resources_runs_path } %>
<% artifacts_path = run_latest_result_path(navigation_context) %>
<% sidebar_items = [
  { label: t("admin.nav.overview"), path: admin_overview_path(navigation_context), icon_key: "overview" }
] %>
<% if shell_role != "operator" %>
  <% runs_item = { label: t("admin.nav.runs"), path: avo.resources_runs_path, icon_key: "runs" } %>
  <% runs_item[:icon_variant] = "sensitive" if shell_role == "admin" %>
  <% sidebar_items << runs_item %>
<% end %>
<% sidebar_items.concat([
  { label: t("admin.nav.validation"), path: admin_overview_ingestion_validation_errors_path(navigation_context), icon_key: "validation" },
  { label: t("admin.nav.artifacts"), path: artifacts_path, external: false, icon_key: "artifacts" },
  { label: t("admin.nav.docs"), path: admin_docs_path(navigation_context), active: true, icon_key: "docs" }
]) %>
<%= render Admin::Shell::AppShellComponent.new(
  sidebar_items: sidebar_items,
  topbar_links: [
    { label: t("admin.nav.docs"), path: admin_docs_path(navigation_context) }
  ],
  breadcrumb: [
    { label: t("admin.nav.workspace"), path: admin_overview_path(navigation_context) },
    { label: t("admin.nav.docs") }
  ],
  environment: nil,
  presence_email: admin_shell_account_email,
  primary_action: nil,
  secondary_action: secondary_action
) do %>
  <main class="workspace">
    <section class="workspace__hero">
      <div class="workspace__intro">
        <p class="workspace__eyebrow"><%= t("admin.docs.index.eyebrow") %></p>
        <h1><%= t("admin.docs.index.title") %></h1>
        <p class="workspace__subtitle"><%= t("admin.docs.index.subtitle") %></p>
      </div>
      <div class="dashboard-card">
        <h2><%= t("admin.docs.index.sections_title") %></h2>
        <ul class="detail-list">
          <% @sections.each do |section| %>
            <li>
              <span><%= section[:title] %></span>
              <strong><%= section[:items].presence || t("admin.docs.index.sections_fallback") %></strong>
            </li>
          <% end %>
        </ul>
      </div>
    </section>
    <section class="workspace__overview">
      <% @sections.each do |section| %>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2><%= section[:title] %></h2>
            <a class="overview__link" href="<%= admin_docs_section_path(section[:slug]) %>"><%= t("admin.common.open") %></a>
          </header>
          <p class="dashboard-card__meta"><%= section[:description] %></p>
          <% if section[:items].present? %>
            <ul class="detail-list">
              <% section[:items].each do |item| %>
                <li><span><%= item %></span></li>
              <% end %>
            </ul>
          <% else %>
            <p class="empty-state"><%= t("admin.docs.index.section_overview") %></p>
          <% end %>
        </section>
      <% end %>
    </section>
  </main>
<% end %>
