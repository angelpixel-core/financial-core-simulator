<% navigation_context = @navigation_context || {} %>
<% shell_role = admin_shell_role %>
<% secondary_action = shell_role == "operator" ? nil : { label: "Open Runs", path: avo.resources_runs_path } %>
<% artifacts_path = run_latest_result_path(navigation_context) %>
<% sidebar_items = [
  { label: "Overview", path: admin_overview_path(navigation_context) }
] %>
<% if shell_role != "operator" %>
  <% runs_item = { label: "Runs", path: avo.resources_runs_path } %>
  <% runs_item[:icon_variant] = "sensitive" if shell_role == "admin" %>
  <% sidebar_items << runs_item %>
<% end %>
<% sidebar_items.concat([
  { label: "Validation", path: admin_overview_ingestion_validation_errors_path(navigation_context) },
  { label: "Artifacts", path: artifacts_path, external: false },
  { label: "Docs", path: admin_docs_path(navigation_context), active: true }
]) %>
<%= render Admin::Shell::AppShellComponent.new(
  sidebar_items: sidebar_items,
  topbar_links: [
    { label: "Docs", path: admin_docs_path(navigation_context) }
  ],
  breadcrumb: [
    { label: "Workspace", path: admin_overview_path(navigation_context) },
    { label: "Docs", path: admin_docs_path(navigation_context) },
    { label: @section[:title] }
  ],
  environment: nil,
  presence_email: admin_shell_account_email,
  primary_action: nil,
  secondary_action: secondary_action
) do %>
  <main class="workspace">
    <section class="workspace__hero">
      <div class="workspace__intro">
        <p class="workspace__eyebrow">DOCS</p>
        <h1><%= @section[:title] %></h1>
        <p class="workspace__subtitle"><%= @section[:description] %></p>
        <div class="workspace__cta-group">
          <a class="workspace__cta workspace__cta--ghost" href="<%= admin_docs_path %>">Back to docs</a>
        </div>
      </div>
      <div class="dashboard-card">
        <h2>Related sections</h2>
        <ul class="detail-list">
          <% @sections.each do |section| %>
            <li>
              <span><%= section[:title] %></span>
              <strong><%= section[:items].presence || "Overview" %></strong>
            </li>
          <% end %>
        </ul>
      </div>
    </section>
    <section class="workspace__overview">
      <section class="dashboard-card">
        <header class="dashboard-card__header">
          <h2>Includes</h2>
        </header>
        <% if @section[:items].present? %>
          <ul class="detail-list">
            <% @section[:items].each do |item| %>
              <li><span><%= item %></span></li>
            <% end %>
          </ul>
        <% else %>
          <p class="empty-state">This section aggregates multiple workspace panels.</p>
        <% end %>
      </section>
      <% if @section[:slug] == "system-state" %>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Como usar System State</h2>
          </header>
          <p class="dashboard-card__meta">
            System State resume la salud operativa actual. Sirve como punto de entrada para detectar
            degradaciones, verificar estabilidad y decidir si conviene profundizar en otras secciones.
          </p>
          <ul class="detail-list">
            <li><span>Uso recomendado</span><strong>Revisar al inicio de cada sesion de monitoreo</strong></li>
            <li><span>Objetivo</span><strong>Confirmar estabilidad y detectar alertas tempranas</strong></li>
            <li><span>Frecuencia</span><strong>Continuo en operaciones, puntual para auditorias</strong></li>
          </ul>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Que podemos leer</h2>
          </header>
          <ul class="detail-list">
            <li><span>Estado operativo</span><strong>Salud general del sistema y confiabilidad</strong></li>
            <li><span>Ultima ejecucion confiable</span><strong>Referencia para comparaciones y trazabilidad</strong></li>
            <li><span>Indicadores clave</span><strong>Duracion promedio, tasa de exito, volumen reciente</strong></li>
          </ul>
          <p class="dashboard-card__meta">
            Si algo se ve inestable aqui, se recomienda saltar a Activity o Data Quality para entender la causa.
          </p>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Valor agregado</h2>
          </header>
          <ul class="detail-list">
            <li><span>Decision rapida</span><strong>Determina si la operacion es confiable ahora mismo</strong></li>
            <li><span>Contexto unico</span><strong>Reune señales que normalmente estan dispersas</strong></li>
            <li><span>Prevencion</span><strong>Detecta degradaciones antes de que escalen</strong></li>
          </ul>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Diagrama de flujo operacional</h2>
          </header>
          <p class="dashboard-card__meta">
            Ver diagrama global en <%= link_to "System State", admin_docs_section_path("system-state") %>.
          </p>
          <div class="dashboard-card__media">
            <%= image_tag "simulation_context_flow.svg", alt: "Flujo de contexto de simulacion" %>
          </div>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Diagrama de arquitectura</h2>
          </header>
          <p class="dashboard-card__meta">
            Ver diagrama global en <%= link_to "System State", admin_docs_section_path("system-state") %>.
          </p>
          <div class="dashboard-card__media">
            <%= image_tag "simulation_context_architecture.svg", alt: "Arquitectura del contexto de simulacion" %>
          </div>
        </section>
      <% end %>
      <% if @section[:slug] == "simulation-context" %>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Como usar Simulation Context</h2>
          </header>
          <p class="dashboard-card__meta">
            Simulation Context define el marco de referencia de cada run: inputs, reglas activas y
            configuraciones que determinan la interpretacion de resultados.
          </p>
          <ul class="detail-list">
            <li><span>Uso recomendado</span><strong>Antes de comparar resultados entre runs</strong></li>
            <li><span>Objetivo</span><strong>Validar que las corridas son comparables</strong></li>
            <li><span>Frecuencia</span><strong>Siempre que cambien inputs o version de engine</strong></li>
          </ul>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Que podemos leer</h2>
          </header>
          <ul class="detail-list">
            <li><span>Input hash</span><strong>Referencia deterministica para reproducibilidad</strong></li>
            <li><span>Schema version</span><strong>Contrato del input usado en la simulacion</strong></li>
            <li><span>Engine version</span><strong>Version del motor de calculo activo</strong></li>
            <li><span>Dataset</span><strong>Fuente de datos base y supuestos implicitos</strong></li>
          </ul>
          <p class="dashboard-card__meta">
            Si cambia el contexto, los resultados no son comparables sin ajustes.
          </p>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Valor agregado</h2>
          </header>
          <ul class="detail-list">
            <li><span>Comparabilidad</span><strong>Evita conclusiones falsas entre runs distintos</strong></li>
            <li><span>Trazabilidad</span><strong>Permite reproducir exactamente un resultado</strong></li>
            <li><span>Auditoria</span><strong>Deja claro que supuestos estaban activos</strong></li>
          </ul>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Diagrama de flujo operacional</h2>
          </header>
          <p class="dashboard-card__meta">
            Ver diagrama global en <%= link_to "System State", admin_docs_section_path("system-state") %>.
          </p>
          <div class="dashboard-card__media">
            <%= image_tag "simulation_context_flow.svg", alt: "Flujo de contexto de simulacion" %>
          </div>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Diagrama de arquitectura</h2>
          </header>
          <p class="dashboard-card__meta">
            Ver diagrama global en <%= link_to "System State", admin_docs_section_path("system-state") %>.
          </p>
          <div class="dashboard-card__media">
            <%= image_tag "simulation_context_architecture.svg", alt: "Arquitectura del contexto de simulacion" %>
          </div>
        </section>
      <% end %>
      <% if @section[:slug] == "system-metrics" %>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Como usar System Metrics</h2>
          </header>
          <p class="dashboard-card__meta">
            System Metrics concentra los KPIs que resumen el rendimiento operativo del sistema y permiten
            evaluar estabilidad, velocidad y salud general.
          </p>
          <ul class="detail-list">
            <li><span>Uso recomendado</span><strong>Antes de tomar decisiones operativas o de capacity</strong></li>
            <li><span>Objetivo</span><strong>Detectar degradaciones de performance o fiabilidad</strong></li>
            <li><span>Frecuencia</span><strong>Revisar diario y ante cambios de carga</strong></li>
          </ul>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Que podemos leer</h2>
          </header>
          <ul class="detail-list">
            <li><span>Total runs (7d/30d)</span><strong>Volumen operativo y tendencia reciente</strong></li>
            <li><span>Success rate</span><strong>Estabilidad de ejecucion en el tiempo</strong></li>
            <li><span>Avg duration</span><strong>Performance y posibles cuellos de botella</strong></li>
            <li><span>KPIs delta</span><strong>Comparacion contra periodos previos</strong></li>
          </ul>
          <p class="dashboard-card__meta">
            Un descenso sostenido en success rate o aumentos de duracion sugieren revisar Activity y Data Quality.
          </p>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Valor agregado</h2>
          </header>
          <ul class="detail-list">
            <li><span>Visibilidad operativa</span><strong>Señales claras sobre performance y salud</strong></li>
            <li><span>Deteccion temprana</span><strong>Se anticipa a problemas de confiabilidad</strong></li>
            <li><span>Prioridad de acciones</span><strong>Ayuda a decidir donde investigar primero</strong></li>
          </ul>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Diagrama de flujo operacional</h2>
          </header>
          <p class="dashboard-card__meta">
            Ver diagrama global en <%= link_to "System State", admin_docs_section_path("system-state") %>.
          </p>
          <div class="dashboard-card__media">
            <%= image_tag "system_metrics_flow.svg", alt: "Flujo operativo de metricas" %>
          </div>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Diagrama de arquitectura</h2>
          </header>
          <p class="dashboard-card__meta">
            Ver diagrama global en <%= link_to "System State", admin_docs_section_path("system-state") %>.
          </p>
          <div class="dashboard-card__media">
            <%= image_tag "system_metrics_architecture.svg", alt: "Arquitectura de metricas" %>
          </div>
        </section>
      <% end %>
      <% if @section[:slug] == "activity" %>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Como usar Activity</h2>
          </header>
          <p class="dashboard-card__meta">
            Activity resume el comportamiento de ejecucion en ventanas recientes y permite detectar
            cambios de ritmo o distribucion de estados.
          </p>
          <ul class="detail-list">
            <li><span>Uso recomendado</span><strong>Cuando cambian patrones de ejecucion</strong></li>
            <li><span>Objetivo</span><strong>Identificar caidas, spikes o degradacion</strong></li>
            <li><span>Frecuencia</span><strong>Monitoreo continuo durante operaciones</strong></li>
          </ul>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Que podemos leer</h2>
          </header>
          <ul class="detail-list">
            <li><span>Run trend (14d)</span><strong>Cadencia y volumen reciente</strong></li>
            <li><span>Status mix (30d)</span><strong>Distribucion de success vs fallas</strong></li>
            <li><span>Picos o huecos</span><strong>Eventos operativos anormales</strong></li>
          </ul>
          <p class="dashboard-card__meta">
            Una mezcla de estados degradada suele anticipar issues en Data Quality.
          </p>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Valor agregado</h2>
          </header>
          <ul class="detail-list">
            <li><span>Contexto temporal</span><strong>Ubica el problema en una linea de tiempo</strong></li>
            <li><span>Deteccion de tendencia</span><strong>Permite ver cambios sostenidos</strong></li>
            <li><span>Priorizacion</span><strong>Indica si investigar o escalar capacidad</strong></li>
          </ul>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Diagrama de flujo operacional</h2>
          </header>
          <p class="dashboard-card__meta">
            Ver diagrama global en <%= link_to "System State", admin_docs_section_path("system-state") %>.
          </p>
          <div class="dashboard-card__media">
            <%= image_tag "activity_flow.svg", alt: "Flujo operacional de actividad" %>
          </div>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Diagrama de arquitectura</h2>
          </header>
          <p class="dashboard-card__meta">
            Ver diagrama global en <%= link_to "System State", admin_docs_section_path("system-state") %>.
          </p>
          <div class="dashboard-card__media">
            <%= image_tag "activity_architecture.svg", alt: "Arquitectura de actividad" %>
          </div>
        </section>
      <% end %>
      <% if @section[:slug] == "financial-results" %>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Como usar Financial Results</h2>
          </header>
          <p class="dashboard-card__meta">
            Financial Results traduce las corridas en señales financieras concretas para entender
            impacto, riesgo y exposicion por cuenta.
          </p>
          <ul class="detail-list">
            <li><span>Uso recomendado</span><strong>Despues de validar que el sistema esta estable</strong></li>
            <li><span>Objetivo</span><strong>Interpretar PnL y exposicion en contexto</strong></li>
            <li><span>Frecuencia</span><strong>Post-run y revisiones de cierre</strong></li>
          </ul>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Que podemos leer</h2>
          </header>
          <ul class="detail-list">
            <li><span>PnL trend</span><strong>Tendencia y direccion del resultado</strong></li>
            <li><span>Latest succeeded run</span><strong>Referencia base para comparacion</strong></li>
            <li><span>Global PnL</span><strong>Impacto consolidado del ultimo run</strong></li>
            <li><span>Top accounts</span><strong>Exposicion y peso relativo</strong></li>
            <li><span>Run comparison</span><strong>Cambios entre runs recientes</strong></li>
            <li><span>Input traceability</span><strong>Relacion entre input y salida</strong></li>
          </ul>
          <p class="dashboard-card__meta">
            Usar esta seccion despues de entender contexto y actividad evita interpretaciones sesgadas.
          </p>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Valor agregado</h2>
          </header>
          <ul class="detail-list">
            <li><span>Contexto financiero</span><strong>Convierte datos tecnicos en impacto</strong></li>
            <li><span>Prioridad de riesgo</span><strong>Enfoca en cuentas y resultados clave</strong></li>
            <li><span>Seguimiento</span><strong>Permite comparar run sobre run</strong></li>
          </ul>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Diagrama de flujo operacional</h2>
          </header>
          <p class="dashboard-card__meta">
            Ver diagrama global en <%= link_to "System State", admin_docs_section_path("system-state") %>.
          </p>
          <div class="dashboard-card__media">
            <%= image_tag "financial_results_flow.svg", alt: "Flujo operacional de resultados" %>
          </div>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Diagrama de arquitectura</h2>
          </header>
          <p class="dashboard-card__meta">
            Ver diagrama global en <%= link_to "System State", admin_docs_section_path("system-state") %>.
          </p>
          <div class="dashboard-card__media">
            <%= image_tag "financial_results_architecture.svg", alt: "Arquitectura de resultados" %>
          </div>
        </section>
      <% end %>
      <% if @section[:slug] == "data-quality" %>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Como usar Data Quality</h2>
          </header>
          <p class="dashboard-card__meta">
            Data Quality concentra los errores de validacion para detectar entradas defectuosas y
            patrones de falla recurrentes.
          </p>
          <ul class="detail-list">
            <li><span>Uso recomendado</span><strong>Cuando el success rate cae o hay fallas recurrentes</strong></li>
            <li><span>Objetivo</span><strong>Identificar rapidamente el origen de errores</strong></li>
            <li><span>Frecuencia</span><strong>Ante alertas o cambios en inputs</strong></li>
          </ul>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Que podemos leer</h2>
          </header>
          <ul class="detail-list">
            <li><span>Fuente</span><strong>Origen del error (pipeline o integracion)</strong></li>
            <li><span>Campo</span><strong>Atributo que falla validacion</strong></li>
            <li><span>Mensaje</span><strong>Descripcion del problema</strong></li>
            <li><span>Correlation</span><strong>Run o lote asociado</strong></li>
          </ul>
          <p class="dashboard-card__meta">
            Filtrar por source/field ayuda a priorizar correcciones.
          </p>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Valor agregado</h2>
          </header>
          <ul class="detail-list">
            <li><span>Calidad de inputs</span><strong>Evita contaminar resultados</strong></li>
            <li><span>Feedback rapido</span><strong>Reduce tiempo de correccion</strong></li>
            <li><span>Prevencion</span><strong>Detecta patrones antes de escalar</strong></li>
          </ul>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Diagrama de flujo operacional</h2>
          </header>
          <p class="dashboard-card__meta">
            Ver diagrama global en <%= link_to "System State", admin_docs_section_path("system-state") %>.
          </p>
          <div class="dashboard-card__media">
            <%= image_tag "data_quality_flow.svg", alt: "Flujo operativo de calidad" %>
          </div>
        </section>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Diagrama de arquitectura</h2>
          </header>
          <p class="dashboard-card__meta">
            Ver diagrama global en <%= link_to "System State", admin_docs_section_path("system-state") %>.
          </p>
          <div class="dashboard-card__media">
            <%= image_tag "data_quality_architecture.svg", alt: "Arquitectura de calidad" %>
          </div>
        </section>
      <% end %>
    </section>
  </main>
<% end %>
