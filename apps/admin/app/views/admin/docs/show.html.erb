<% navigation_context = @navigation_context || {} %>
<% shell_role = admin_shell_role %>
<% secondary_action = shell_role == "operator" ? nil : { label: "Open Runs", path: avo.resources_runs_path } %>
<% artifacts_path = avo.resources_runs_path %>
<% sidebar_items = [
  { label: "Overview", path: admin_overview_path(navigation_context) }
] %>
<% if shell_role != "operator" %>
  <% runs_item = { label: "Runs", path: avo.resources_runs_path } %>
  <% runs_item[:icon_variant] = "sensitive" if shell_role == "admin" %>
  <% sidebar_items << runs_item %>
<% end %>
<% sidebar_items.concat([
  { label: "Validation", path: admin_overview_ingestion_validation_errors_path(navigation_context) },
  { label: "Artifacts", path: artifacts_path },
  { label: "Docs", path: admin_docs_path(navigation_context), active: true }
]) %>
<%= render Admin::Shell::AppShellComponent.new(
  sidebar_items: sidebar_items,
  topbar_links: [
    { label: "Docs", path: admin_docs_path(navigation_context) }
  ],
  breadcrumb: [
    { label: "Workspace", path: admin_overview_path(navigation_context) },
    { label: "Docs", path: admin_docs_path(navigation_context) },
    { label: @section[:title] }
  ],
  environment: nil,
  presence_email: admin_shell_account_email,
  primary_action: nil,
  secondary_action: secondary_action
) do %>
  <main class="workspace">
    <section class="workspace__hero">
      <div class="workspace__intro">
        <p class="workspace__eyebrow">DOCS</p>
        <h1><%= @section[:title] %></h1>
        <p class="workspace__subtitle"><%= @section[:description] %></p>
        <div class="workspace__cta-group">
          <a class="workspace__cta workspace__cta--ghost" href="<%= admin_docs_path %>">Back to docs</a>
        </div>
      </div>
      <div class="dashboard-card">
        <h2>Related sections</h2>
        <ul class="detail-list">
          <% @sections.each do |section| %>
            <li>
              <span><%= section[:title] %></span>
              <strong><%= section[:items].presence || "Overview" %></strong>
            </li>
          <% end %>
        </ul>
      </div>
    </section>
    <section class="workspace__overview">
      <section class="dashboard-card">
        <header class="dashboard-card__header">
          <h2>Includes</h2>
        </header>
        <% if @section[:items].present? %>
          <ul class="detail-list">
            <% @section[:items].each do |item| %>
              <li><span><%= item %></span></li>
            <% end %>
          </ul>
        <% else %>
          <p class="empty-state">This section aggregates multiple workspace panels.</p>
        <% end %>
      </section>

      <% if @section[:slug] == "system-state" %>
        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Como usar System State</h2>
          </header>
          <p class="dashboard-card__meta">
            System State resume la salud operativa actual. Sirve como punto de entrada para detectar
            degradaciones, verificar estabilidad y decidir si conviene profundizar en otras secciones.
          </p>
          <ul class="detail-list">
            <li><span>Uso recomendado</span><strong>Revisar al inicio de cada sesion de monitoreo</strong></li>
            <li><span>Objetivo</span><strong>Confirmar estabilidad y detectar alertas tempranas</strong></li>
            <li><span>Frecuencia</span><strong>Continuo en operaciones, puntual para auditorias</strong></li>
          </ul>
        </section>

        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Que podemos leer</h2>
          </header>
          <ul class="detail-list">
            <li><span>Estado operativo</span><strong>Salud general del sistema y confiabilidad</strong></li>
            <li><span>Ultima ejecucion confiable</span><strong>Referencia para comparaciones y trazabilidad</strong></li>
            <li><span>Indicadores clave</span><strong>Duracion promedio, tasa de exito, volumen reciente</strong></li>
          </ul>
          <p class="dashboard-card__meta">
            Si algo se ve inestable aqui, se recomienda saltar a Activity o Data Quality para entender la causa.
          </p>
        </section>

        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Valor agregado</h2>
          </header>
          <ul class="detail-list">
            <li><span>Decision rapida</span><strong>Determina si la operacion es confiable ahora mismo</strong></li>
            <li><span>Contexto unico</span><strong>Reune señales que normalmente estan dispersas</strong></li>
            <li><span>Prevencion</span><strong>Detecta degradaciones antes de que escalen</strong></li>
          </ul>
        </section>

        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Diagrama de flujo operacional</h2>
          </header>
          <div class="dashboard-card__media">
            <%= image_tag "ops_flow_diagram.svg", alt: "Flujo operacional del dashboard" %>
          </div>
        </section>

        <section class="dashboard-card">
          <header class="dashboard-card__header">
            <h2>Diagrama de arquitectura</h2>
          </header>
          <div class="dashboard-card__media">
            <%= image_tag "architecture_diagram.svg", alt: "Arquitectura del sistema" %>
          </div>
        </section>
      <% end %>
    </section>
  </main>
<% end %>
