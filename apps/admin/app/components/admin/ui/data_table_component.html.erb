<table class="ui-data-table <%= @table_class %>">
  <thead>
    <tr>
      <% @columns.each do |column| %>
        <th><%= column.fetch(:label) %></th>
      <% end %>
    </tr>
  </thead>
  <tbody>
    <% if loading? %>
      <tr>
        <td colspan="<%= column_count %>"><%= @loading_message %></td>
      </tr>
    <% elsif error? %>
      <tr>
        <td colspan="<%= column_count %>"><%= @error_message %></td>
      </tr>
    <% elsif empty? %>
      <tr>
        <td colspan="<%= column_count %>">No account totals available.</td>
      </tr>
    <% else %>
      <% @rows.each do |row| %>
        <tr>
          <% @columns.each do |column| %>
            <td><%= row.fetch(column.fetch(:key), "-") %></td>
          <% end %>
        </tr>
      <% end %>
    <% end %>
  </tbody>
</table>
