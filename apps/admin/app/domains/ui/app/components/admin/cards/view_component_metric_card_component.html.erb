  <h3 style="margin:4px 0 8px 0;"><%= @title %></h3>
  <p style="margin:0; font-size:24px; font-weight:700;"><%= @value %></p>
  <p style="margin:8px 0 0 0; color:#4b5563;"><%= @info %></p>
</article>
