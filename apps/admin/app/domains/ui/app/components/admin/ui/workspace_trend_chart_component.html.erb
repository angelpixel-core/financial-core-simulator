<div
  data-controller="run-trend-chart"
  data-run-trend-chart-points-value="<%= @points.to_json %>"
  data-run-trend-chart-chart-kind-value="bar"
  data-run-trend-chart-tooltip-label-value="<%= t("admin.common.day") %>"
  data-run-trend-chart-tooltip-count-label-value="<%= t("admin.common.runs") %>"
  <% if title_value.present? %>
    data-run-trend-chart-title-value="<%= title_value %>"
  <% end %>
  data-run-trend-chart-animation-mode-value="proportional"
  data-run-trend-chart-base-duration-value="260"
  data-run-trend-chart-max-extra-duration-value="540"
>
  <div
    class="<%= trend_class %>"
    data-run-trend-chart-target="chart"
    aria-label="<%= t("admin.overview.activity.run_trend.aria") %>"
  ></div>
  <div class="trend-bars" data-run-trend-chart-target="fallback">
    <% @points.each do |point| %>
      <% height = ((point[:count].to_f / max_trend) * 100).round(1) %>
      <div class="trend-bars__item">
        <div class="trend-bars__bar-wrap">
          <div class="trend-bars__bar" style="height: <%= height %>%" title="<%= t("admin.common.runs_tooltip", day: point[:day], count: point[:count]) %>" data-tooltip="<%= t("admin.common.runs_tooltip", day: point[:day], count: point[:count]) %>" aria-label="<%= t("admin.common.runs_tooltip", day: point[:day], count: point[:count]) %>" tabindex="0"></div>
        </div>
        <span><%= point[:day] %></span>
      </div>
    <% end %>
  </div>
</div>
