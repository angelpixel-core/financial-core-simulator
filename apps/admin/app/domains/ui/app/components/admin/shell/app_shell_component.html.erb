<div class="app-shell" data-controller="sidebar" data-sidebar-storage-key-value="admin.shell.sidebar.collapsed" data-sidebar-collapsed-class="app-shell--sidebar-collapsed">
  <a class="app-shell__skip-link" href="#workspace-main"><%= t("admin.shell.skip_to_content") %></a>
  <aside class="app-shell__sidebar" aria-label="<%= t("admin.shell.sidebar_aria") %>">
    <div class="app-shell__sidebar-header">
      <div class="app-shell__brand app-shell__brand--panel">
        <button
          type="button"
          class="app-shell__brand-mark app-shell__brand-mark--trigger"
          data-action="sidebar#expand"
          aria-label="<%= t("admin.shell.expand_sidebar") %>"
          title="<%= t("admin.shell.expand_sidebar") %>"
        >
          <%= image_tag "fcs_logo_dark_minimal.svg", class: "app-shell__brand-logo", alt: "FCS" %>
        </button>
        <div class="app-shell__brand-copy">
          <span class="app-shell__brand-title"><%= t("admin.shell.brand_title") %></span>
          <span class="app-shell__brand-subtitle"><%= t("admin.shell.brand_subtitle") %></span>
        </div>
        <button
          type="button"
          class="app-shell__collapse-toggle"
          data-action="sidebar#toggle"
          data-sidebar-target="toggle"
          aria-label="<%= t("admin.shell.collapse_sidebar") %>"
          title="<%= t("admin.shell.collapse_sidebar") %>"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="16" rx="2"></rect>
            <path d="M9 4v16"></path>
          </svg>
        </button>
      </div>
    </div>
    <details class="app-shell__mobile-nav">
      <summary class="app-shell__mobile-nav-toggle" aria-label="<%= t("admin.shell.mobile_nav_toggle") %>">
        <span class="app-shell__brand-mark" aria-hidden="true">
          <%= image_tag "fcs_logo_dark_minimal.svg", class: "app-shell__brand-logo", alt: "" %>
        </span>
        <span class="app-shell__mobile-nav-toggle-brand-copy">
          <span class="app-shell__brand-title"><%= t("admin.shell.brand_title") %></span>
          <span class="app-shell__brand-subtitle"><%= t("admin.shell.brand_subtitle") %></span>
        </span>
        <span class="app-shell__mobile-nav-toggle-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 9l6 6 6-6"></path>
          </svg>
        </span>
      </summary>
      <nav class="app-shell__mobile-nav-sheet" aria-label="<%= t("admin.shell.mobile_nav_aria") %>">
        <p class="app-shell__nav-group-label"><%= t("admin.shell.navigation_label") %></p>
        <% @sidebar_items.each do |item| %>
          <% classes = ["app-shell__nav-link"] %>
          <% icon_classes = ["app-shell__nav-icon"] %>
          <% classes << "app-shell__nav-link--active" if item[:active] %>
          <% classes << "app-shell__nav-link--disabled" if item[:disabled] %>
          <% icon_classes << "app-shell__nav-icon--#{item[:icon_variant]}" if item[:icon_variant].present? %>
          <% if item[:disabled] %>
            <span class="<%= classes.join(" ") %>" aria-disabled="true" title="<%= item[:label] %>">
              <span class="<%= icon_classes.join(" ") %>"><%= icon_svg_for(item) %></span>
              <span class="app-shell__nav-label"><%= item[:label] %></span>
            </span>
          <% else %>
            <a
              class="<%= classes.join(" ") %>"
              href="<%= item[:path] %>"
              title="<%= item[:label] %>"
              <%= item[:active] ? 'aria-current="page"' : "" %>
              <%= item[:external] ? "target=\"_blank\" rel=\"noopener noreferrer\"" : "" %>
            >
              <span class="<%= icon_classes.join(" ") %>"><%= icon_svg_for(item) %></span>
              <span class="app-shell__nav-label"><%= item[:label] %></span>
            </a>
          <% end %>
        <% end %>
      </nav>
    </details>
    <nav class="app-shell__nav app-shell__nav--desktop">
      <p class="app-shell__nav-group-label"><%= t("admin.shell.navigation_label") %></p>
      <% @sidebar_items.each do |item| %>
        <% classes = ["app-shell__nav-link"] %>
        <% icon_classes = ["app-shell__nav-icon"] %>
        <% classes << "app-shell__nav-link--active" if item[:active] %>
        <% classes << "app-shell__nav-link--disabled" if item[:disabled] %>
        <% icon_classes << "app-shell__nav-icon--#{item[:icon_variant]}" if item[:icon_variant].present? %>
        <% if item[:disabled] %>
          <span class="<%= classes.join(" ") %>" aria-disabled="true" title="<%= item[:label] %>">
            <span class="<%= icon_classes.join(" ") %>"><%= icon_svg_for(item) %></span>
            <span class="app-shell__nav-label"><%= item[:label] %></span>
          </span>
        <% else %>
          <a
            class="<%= classes.join(" ") %>"
            href="<%= item[:path] %>"
            title="<%= item[:label] %>"
            <%= item[:active] ? 'aria-current="page"' : "" %>
            <%= item[:external] ? "target=\"_blank\" rel=\"noopener noreferrer\"" : "" %>
          >
            <span class="<%= icon_classes.join(" ") %>"><%= icon_svg_for(item) %></span>
            <span class="app-shell__nav-label"><%= item[:label] %></span>
          </a>
        <% end %>
      <% end %>
    </nav>
    <div
      class="app-shell__sidebar-footer"
      data-controller="workspace-presence"
      data-action="mouseenter->workspace-presence#enter mouseleave->workspace-presence#leave focusin->workspace-presence#enter focusout->workspace-presence#leave"
      tabindex="0"
      >
      <span class="app-shell__sidebar-footer-dot" data-workspace-presence-target="dot"></span>
      <span class="app-shell__sidebar-footer-copy" data-workspace-presence-target="label">
        <span class="app-shell__sidebar-footer-text app-shell__sidebar-footer-text--base"><%= t("admin.shell.presence_stable") %></span>
        <span class="app-shell__sidebar-footer-text app-shell__sidebar-footer-text--hover"><%= t("admin.shell.presence_online", email: @presence_email) %></span>
      </span>
    </div>
  </aside>
  <div class="app-shell__content">
    <header class="app-shell__topbar" aria-label="<%= t("admin.shell.topbar_aria") %>">
      <nav class="app-shell__breadcrumb" aria-label="<%= t("admin.shell.breadcrumb_aria") %>">
        <ol>
          <% @breadcrumb.each do |crumb| %>
            <li>
              <% if crumb[:path].present? %>
                <a href="<%= crumb[:path] %>"><%= crumb[:label] %></a>
              <% else %>
                <span><%= crumb[:label] %></span>
              <% end %>
            </li>
          <% end %>
        </ol>
      </nav>
      <div class="app-shell__topbar-actions">
        <% if @topbar_links.any? %>
          <div class="app-shell__topbar-links" aria-label="<%= t("admin.shell.resources_aria") %>">
            <% @topbar_links.each do |link| %>
              <a
                class="app-shell__topbar-link"
                href="<%= link[:path] %>"
                <%= link[:external] ? "target=\"_blank\" rel=\"noopener noreferrer\"" : "" %>
              ><%= link[:label] %></a>
            <% end %>
          </div>
        <% end %>
        <% if @environment.present? %>
          <span class="app-shell__env-badge"><%= t("admin.shell.env_badge", environment: @environment) %></span>
        <% end %>
        <% if @secondary_action.present? %>
          <a class="app-shell__cta app-shell__cta--ghost" href="<%= @secondary_action[:path] %>"><%= @secondary_action[:label] %></a>
        <% end %>
        <% if @primary_action.present? %>
          <% if @primary_action[:disabled] %>
            <span class="app-shell__cta app-shell__cta--disabled" aria-disabled="true"><%= @primary_action[:label] %></span>
          <% else %>
            <a class="app-shell__cta" href="<%= @primary_action[:path] %>"><%= @primary_action[:label] %></a>
          <% end %>
        <% end %>
      </div>
    </header>
    <div class="app-shell__main" id="workspace-main" tabindex="-1">
      <%= content %>
    </div>
  </div>
</div>
